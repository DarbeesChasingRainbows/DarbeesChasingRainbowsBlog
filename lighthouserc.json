{
	"//": "Lighthouse CI config. Runs against the local preview server in CI.",
	"//assert": "Thresholds chosen to be honest baselines, not aspirational. Bump them as the site improves so regressions surface.",
	"ci": {
		"collect": {
			"staticDistDir": "./dist",
			"url": [
				"http://localhost/index.html",
				"http://localhost/blog/charlotte-masons-companion/index.html",
				"http://localhost/projects/off-grid-power-solar-setup/index.html",
				"http://localhost/field-notes/bulow-plantation-ruins/index.html",
				"http://localhost/bookshelf/index.html",
				"http://localhost/bookshelf/wingfeather-saga-book-one/index.html"
			],
			"numberOfRuns": 1,
			"settings": {
				"preset": "desktop"
			}
		},
		"assert": {
			"assertions": {
				"categories:performance": ["error", { "minScore": 0.9 }],
				"categories:accessibility": ["error", { "minScore": 0.9 }],
				"categories:best-practices": ["error", { "minScore": 0.9 }],
				"categories:seo": ["error", { "minScore": 0.95 }],
				"//note": "Color-contrast and image-alt are the two most-likely-to-fail a11y checks for this site; assert them explicitly so a regression surfaces with a clear message",
				"color-contrast": "error",
				"image-alt": "error"
			}
		},
		"upload": {
			"target": "temporary-public-storage"
		}
	}
}
