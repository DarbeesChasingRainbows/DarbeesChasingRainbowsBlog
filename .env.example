# Copy this file to `.env` for local development.
# In production (Cloudflare Pages), set these in the project's
# Settings → Environment variables panel — do NOT commit a real .env.
#
# All keys here are PUBLIC (inlined into the client bundle at build time).
# Anything secret should be a server-only variable, not PUBLIC_*.

# -----------------------------------------------------------------------------
# Cloudflare Web Analytics
# -----------------------------------------------------------------------------
# Beacon token from the Cloudflare dashboard → Analytics → Web Analytics →
# your site → "Manage site" → JavaScript snippet (the value of `data-cf-beacon`).
# When unset, the analytics script is not emitted (BaseHead.astro:82).
PUBLIC_CLOUDFLARE_ANALYTICS_TOKEN=

# -----------------------------------------------------------------------------
# Buttondown newsletter
# -----------------------------------------------------------------------------
# The handle is the trailing path of your Buttondown embed URL, e.g. for
# `https://buttondown.email/api/emails/embed-subscribe/darbees`, the handle
# is `darbees`. When unset, NewsletterSignup.astro renders nothing (or
# whatever fallback you wired up — see the FALLBACK_PLACEHOLDER block).
PUBLIC_BUTTONDOWN_HANDLE=

# -----------------------------------------------------------------------------
# Phase 12 dev environment (podman compose stack)
# -----------------------------------------------------------------------------
# Used by `make up` / `compose.yaml`. See docs/dev-environment.md.

# Local ArangoDB root password. Dev default is fine; pick anything for local.
ARANGO_ROOT_PASSWORD=password

# LM Studio API token. Generate one in LM Studio's developer settings.
# Required from Phase 11 Task A6 onward (when the embedding client is wired
# into DI). Leave blank if you only need the arango stack and don't have LM
# Studio running yet.
LMSTUDIO_API_KEY=

# LM Studio model identifier. Both chat completions and embeddings use this
# name to reach the loaded model. Defaults to "local-model" when unset.
AI_MODEL_ID=
# Vision-capable model id for the image-watcher alt-text script (image:watch).
AI_VISION_MODEL_ID=
# Embedding model id for the related-posts rebuild script (related:rebuild).
AI_EMBEDDING_MODEL_ID=

# ArangoDB database name used by the DAIS Bridge. Defaults to
# "darbees_knowledge" when unset; override here if you want a per-machine name.
ARANGO_DATABASE=
