# Directus CMS Configuration
# Copy to .env and customize as needed

# Admin credentials (set during docker run)
DIRECTUS_URL=http://localhost:8055
DIRECTUS_ADMIN_EMAIL=admin@darbees.local
DIRECTUS_ADMIN_PASSWORD=localdev
DIRECTUS_SECRET=replace-with-random-value

# LM Studio (GEO Optimizer)
LM_STUDIO_URL=http://host.docker.internal:1234/v1

# Content export path (inside container)
CONTENT_EXPORT_PATH=/directus/astro-content
