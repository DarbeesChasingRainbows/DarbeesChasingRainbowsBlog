{
	"plugins": ["prettier-plugin-astro", "prettier-plugin-tailwindcss"],
	"useTabs": true,
	"tabWidth": 2,
	"singleQuote": true,
	"semi": true,
	"trailingComma": "all",
	"printWidth": 100,
	"overrides": [
		{
			"files": "*.astro",
			"options": {
				"parser": "astro"
			}
		},
		{
			"files": ["*.md", "*.mdx"],
			"options": {
				"useTabs": false,
				"tabWidth": 2,
				"proseWrap": "preserve"
			}
		}
	]
}
