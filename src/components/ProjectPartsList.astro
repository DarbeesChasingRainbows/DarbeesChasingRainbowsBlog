---
interface Part {
	name: string;
	quantity?: number;
	url?: string;
	notes?: string;
}

interface Props {
	items: Part[];
	title?: string;
}

const { items, title = 'Parts List' } = Astro.props;
---

<section class="border-base-300 bg-base-200/40 my-8 overflow-hidden rounded-2xl border">
	<header class="bg-base-200 border-base-300 border-b px-5 py-3">
		<h3 class="font-display m-0 text-lg font-bold">{title}</h3>
	</header>
	<div class="overflow-x-auto">
		<table class="table">
			<thead>
				<tr>
					<th>Part</th>
					<th class="w-20 text-right">Qty</th>
					<th>Notes</th>
				</tr>
			</thead>
			<tbody>
				{
					items.map((part) => (
						<tr>
							<td class="font-medium">
								{part.url ? (
									<a
										href={part.url}
										target="_blank"
										rel="noopener nofollow"
										class="link link-primary"
									>
										{part.name}
									</a>
								) : (
									part.name
								)}
							</td>
							<td class="text-right tabular-nums">{part.quantity ?? '—'}</td>
							<td class="text-base-content/80 text-sm">{part.notes ?? ''}</td>
						</tr>
					))
				}
			</tbody>
		</table>
	</div>
</section>
