---
import { BUTTONDOWN_HANDLE } from '../consts';

interface Props {
	compact?: boolean;
}

const { compact = false } = Astro.props;

// Newsletter is "configured" when PUBLIC_BUTTONDOWN_HANDLE is set in env.
// When unconfigured (dev, pre-launch, or env misconfig in prod), this
// component renders nothing — the form is hidden rather than rendered
// in a broken or placeholder state. See README "Environment variables".
const isConfigured = BUTTONDOWN_HANDLE.length > 0;
const formAction = `https://buttondown.email/api/emails/embed-subscribe/${BUTTONDOWN_HANDLE}`;
---

{
	isConfigured && (
		<div class:list={['text-center', compact ? '' : 'mx-auto max-w-xl']}>
			{!compact && (
				<>
					<div class="bg-primary/10 text-primary mb-6 inline-flex h-14 w-14 items-center justify-center rounded-2xl">
						<svg
							xmlns="http://www.w3.org/2000/svg"
							class="h-7 w-7"
							viewBox="0 0 20 20"
							fill="currentColor"
						>
							<path d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z" />
							<path d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z" />
						</svg>
					</div>
					<h3 class="font-display mb-3 text-2xl font-bold md:text-3xl">Follow the journey</h3>
					<p class="text-base-content/70 mb-8 text-base leading-relaxed">
						Get RV life updates, field notes, homeschool lessons, and useful builds — straight to
						your inbox. No spam, ever.
					</p>
				</>
			)}
			{compact && (
				<div class="text-left">
					<h3 class="font-display mb-2 text-lg font-bold">Stay in the loop</h3>
					<p class="text-base-content/70 mb-3 text-sm">
						Field notes, projects, and updates from the road.
					</p>
				</div>
			)}
			<form
				class="flex flex-col gap-3 sm:flex-row"
				action={formAction}
				method="post"
				target="_blank"
			>
				<label class="sr-only" for="newsletter-email">
					Email address
				</label>
				<input
					id="newsletter-email"
					type="email"
					name="email"
					required
					placeholder="you@example.com"
					class="input input-bordered bg-base-100 focus:bg-base-100 flex-1"
				/>
				<button
					type="submit"
					class="btn btn-primary shadow-primary/20 hover:shadow-primary/30 shadow-lg transition-all hover:shadow-xl"
				>
					{compact ? 'Subscribe' : 'Get Updates'}
				</button>
			</form>
			<p class="text-base-content/50 mt-3 text-xs">Unsubscribe anytime. We respect your inbox.</p>
		</div>
	)
}
