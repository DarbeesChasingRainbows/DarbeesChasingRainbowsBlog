---
import { formatDate, formatDateISO } from '../utils/formatDate';

interface Props {
	date: Date | string;
	class?: string;
}

const { date, class: className } = Astro.props;
const d = typeof date === 'string' ? new Date(date) : date;
---

<time datetime={formatDateISO(d)} class={className}>
	{formatDate(d)}
</time>
