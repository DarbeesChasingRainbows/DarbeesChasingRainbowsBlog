---
interface Props {
  author?: string;
  context?: string;
}

const { author, context } = Astro.props;
---
<blockquote class="not-prose relative my-10 p-8 border-l-4 border-primary bg-base-200/50 rounded-r-box shadow-sm italic text-lg text-base-content/90">
  <div class="absolute top-4 left-4 text-6xl text-primary/20 font-serif leading-none select-none">"</div>
  <div class="relative z-10 leading-relaxed">
    <slot />
  </div>
  {(author || context) && (
    <footer class="mt-4 pt-4 border-t border-base-content/10 not-italic flex flex-col sm:flex-row sm:items-center gap-2">
      {author && <strong class="text-base-content font-medium">{author}</strong>}
      {author && context && <span class="hidden sm:inline text-base-content/40">•</span>}
      {context && <span class="text-sm text-base-content/70">{context}</span>}
    </footer>
  )}
</blockquote>
