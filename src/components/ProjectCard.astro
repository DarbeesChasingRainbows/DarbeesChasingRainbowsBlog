---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import CategoryPill from './CategoryPill.astro';

interface Props {
	project: CollectionEntry<'projects'>;
	compact?: boolean;
}

const { project, compact = false } = Astro.props;
const { data, id } = project;
const hero = data.featuredImage ?? data.heroImage;

const difficultyColor = {
	easy: 'badge-success',
	medium: 'badge-warning',
	hard: 'badge-error',
};
---

<a href={`/projects/${id}/`} class="group block">
	{
		hero && (
			<figure class:list={["relative overflow-hidden rounded-2xl bg-base-200 ring-1 ring-base-300/60 mb-4", compact ? "aspect-2/1" : "aspect-4/3"]}>
				<Image
					src={hero}
					alt={data.title}
					width={800}
					height={600}
					class="h-full w-full object-cover transition-transform duration-700 ease-out group-hover:scale-[1.06]"
				/>
				<span class="absolute top-3 left-3 inline-flex items-center gap-1 px-2.5 py-1 rounded-full bg-base-100/90 backdrop-blur-sm text-[10px] font-display font-bold tracking-[0.18em] uppercase text-primary shadow-sm">
					{data.category}
				</span>
				{data.difficulty && (
					<span class={`absolute top-3 right-3 badge ${difficultyColor[data.difficulty]} badge-soft text-[10px] font-bold tracking-[0.15em] uppercase`}>
						{data.difficulty}
					</span>
				)}
			</figure>
		)
	}
	<div class="space-y-2">
		{!hero && (
			<div class="flex items-center gap-2">
				<span class="text-[10px] font-display font-bold tracking-[0.22em] uppercase text-primary">{data.category}</span>
				{data.difficulty && (
					<span class={`badge ${difficultyColor[data.difficulty]} badge-soft text-[10px] uppercase tracking-wider`}>{data.difficulty}</span>
				)}
			</div>
		)}
		<h3 class:list={["font-editorial text-base-content", compact ? "text-xl" : "text-2xl md:text-[1.65rem]"]}>
			<span class="title-sweep">{data.title}</span>
		</h3>
		<p class="text-base-content/65 leading-relaxed text-[0.95rem] line-clamp-2">{data.description}</p>
		{(data.estimatedCost || data.estimatedTime) && (
			<div class="flex flex-wrap items-center gap-3 text-[11px] font-display font-semibold tracking-[0.15em] uppercase text-base-content/55 pt-1">
				{data.estimatedCost && (
					<span class="inline-flex items-center gap-1">
						<svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" viewBox="0 0 20 20" fill="currentColor"><path d="M10 2a6 6 0 00-6 6v3.586l-.707.707A1 1 0 004 14h12a1 1 0 00.707-1.707L16 11.586V8a6 6 0 00-6-6zM10 18a3 3 0 01-3-3h6a3 3 0 01-3 3z"/></svg>
						{data.estimatedCost}
					</span>
				)}
				{data.estimatedTime && (
					<span class="inline-flex items-center gap-1">
						<svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd"/></svg>
						{data.estimatedTime}
					</span>
				)}
				<span class="flex-1 border-t border-dashed border-base-content/20"></span>
				<span class="inline-flex items-center gap-1 text-primary group-hover:gap-2 transition-all">
					Build
					<svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"/></svg>
				</span>
			</div>
		)}
	</div>
</a>
