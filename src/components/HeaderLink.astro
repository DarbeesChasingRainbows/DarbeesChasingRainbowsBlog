---
interface Props {
	href: string;
	class?: string;
}

const { href, class: className, ...rest } = Astro.props;
const pathname = Astro.url.pathname;
const isActive = pathname === href || (href !== '/' && pathname.startsWith(href + '/'));
---

<a
	href={href}
	class:list={[
		'link-reveal px-1 py-1 font-display text-[10px] font-bold tracking-[0.18em] uppercase transition-colors',
		isActive ? 'text-primary' : 'text-base-content/70 hover:text-primary',
		className,
	]}
	aria-current={isActive ? 'page' : undefined}
	{...rest}
>
	<slot />
</a>
