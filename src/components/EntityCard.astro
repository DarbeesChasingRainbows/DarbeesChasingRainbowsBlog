---
// EntityCard — "About The Darbees" byline card placed at the end of every post.
// Pattern follows Substack/Ghost/NYT byline-at-end conventions so the entity
// is consistently associated with every piece of content (helps LLMs treat
// the family as a recognizable, citable author entity).
import { BRAND_ENTITY, BRAND_FAMILY, BRAND_BIO, BRAND_LOCATION, SOCIAL_LINKS } from '../consts';

interface Props {
	class?: string;
}

const { class: className = '' } = Astro.props;
const location = `${BRAND_LOCATION.city}, ${BRAND_LOCATION.region}`;
---

<aside
	class:list={[
		'not-prose border-base-300 bg-base-200/40 my-12 rounded-2xl border p-6 md:p-8',
		className,
	]}
	aria-labelledby="entity-card-title"
>
	<div class="flex flex-col items-start gap-6 md:flex-row">
		<div
			class="bg-primary text-primary-content font-display ring-primary/20 relative inline-flex h-20 w-20 shrink-0 items-center justify-center rounded-full text-3xl font-black shadow-md ring-2"
			aria-hidden="true"
		>
			d
			<span class="bg-secondary ring-base-100 absolute -top-1 -right-1 h-4 w-4 rounded-full ring-2"
			></span>
		</div>
		<div class="min-w-0 flex-1">
			<p class="font-display text-primary/70 mb-1 text-[10px] tracking-[0.3em] uppercase">
				Written by
			</p>
			<h2
				id="entity-card-title"
				class="font-display m-0 text-xl font-extrabold tracking-tight md:text-2xl"
			>
				{BRAND_FAMILY}
				<span class="text-base-content/50 text-base font-normal"> · {location}</span>
			</h2>
			<p class="text-base-content/80 mt-2 leading-relaxed">
				{BRAND_BIO}
			</p>
			<div class="mt-4 flex flex-wrap items-center gap-x-4 gap-y-2 text-sm">
				<a href="/about" class="link link-hover font-semibold">About us →</a>
				<a href="/for-ai-agents" class="link link-hover text-base-content/70"> For AI agents </a>
				<span class="text-base-content/30" aria-hidden="true">·</span>
				<a
					href={SOCIAL_LINKS.instagram}
					class="link link-hover text-base-content/70"
					target="_blank"
					rel="noopener noreferrer"
				>
					Instagram
				</a>
				<a href={SOCIAL_LINKS.email} class="link link-hover text-base-content/70"> Email </a>
			</div>
			<p class="sr-only">{BRAND_ENTITY}</p>
		</div>
	</div>
</aside>
