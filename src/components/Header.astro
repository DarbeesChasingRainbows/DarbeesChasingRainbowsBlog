---
import { NAV_LINKS } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header class="relative z-40 w-full pt-2">
	<!-- Background layers -->
	<div class="absolute inset-x-0 top-0 h-14 bg-primary -z-10"></div>
	<div class="absolute inset-x-0 top-14 bottom-0 bg-base-100 -z-10 border-b border-base-content/10"></div>

	<div class="mx-auto max-w-[90rem] px-6 pb-4 flex items-start justify-between">
		
		<!-- Left: Logos -->
		<div class="flex flex-col mt-3">
			<a href="/" class="group flex flex-col" aria-label="Darbees Chasing Rainbows — home">
				<span class="font-display font-black text-3xl tracking-tight text-primary-content">darbees</span>
				<!-- This text sits in the off-white area below the green strip -->
				<span class="font-display text-[10px] font-bold tracking-[0.25em] uppercase text-base-content/60 mt-5 pl-1">
					Chasing Rainbows
				</span>
			</a>
		</div>

		<!-- Right: The Nav Pill -->
		<div class="relative flex flex-col items-center mt-2">
			<!-- The 'd' logo sits at the very top, overlapping the green and pill -->
			<div class="absolute -top-4 z-20">
				<a href="/" aria-label="Home" class="relative inline-flex items-center justify-center w-10 h-10 rounded-full bg-base-100 text-primary font-display font-black text-xl shadow-sm ring-1 ring-base-content/10 hover:text-accent transition-colors">
					d
				</a>
			</div>
			
			<!-- The rounded pill -->
			<nav class="bg-base-100 rounded-full shadow-sm ring-1 ring-base-content/10 px-3 py-2 flex items-center mt-1" aria-label="Primary">
				
				<!-- Left nav links -->
				<ul class="hidden xl:flex items-center gap-6 pl-4 pr-8">
					{NAV_LINKS.slice(0, 3).map((link) => (
						<li>
							<HeaderLink href={link.href}>{link.label}</HeaderLink>
						</li>
					))}
				</ul>

				<!-- Spacer for the 'd' logo -->
				<div class="hidden xl:block w-8"></div>

				<!-- Right nav links -->
				<ul class="hidden xl:flex items-center gap-6 pl-8 pr-4">
					{NAV_LINKS.slice(3).map((link) => (
						<li>
							<HeaderLink href={link.href}>{link.label}</HeaderLink>
						</li>
					))}
					<li>
						<a
							href="/rss.xml"
							class="link-reveal px-1 py-1 font-display text-[10px] font-bold tracking-[0.18em] uppercase text-base-content/70 hover:text-primary transition-colors"
							aria-label="RSS feed"
						>RSS</a>
					</li>
				</ul>

				<!-- Say Hi (right, green) -->
				<a
					href="/contact"
					class="hidden md:inline-flex items-center justify-center w-12 h-12 rounded-full bg-primary text-primary-content text-[11px] font-display font-bold tracking-[0.12em] uppercase hover:bg-accent hover:text-accent-content transition-colors shrink-0 shadow-md ml-4"
				>
					Say Hi
				</a>

				<!-- Mobile hamburger -->
				<details class="dropdown dropdown-end xl:hidden ml-4">
					<summary class="list-none cursor-pointer p-3 rounded-full hover:bg-base-200 transition-colors" aria-label="Open menu">
						<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-base-content" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7h16M4 12h16M4 17h16"/>
						</svg>
					</summary>
					<ul class="dropdown-content bg-base-100 rounded-2xl z-10 mt-3 w-60 p-3 shadow-xl border border-base-300 space-y-1">
						{NAV_LINKS.map((link) => (
							<li><HeaderLink href={link.href}>{link.label}</HeaderLink></li>
						))}
						<li class="pt-2 mt-2 border-t border-base-300">
							<a href="/contact" class="link-reveal px-1 py-1 font-display text-sm font-semibold tracking-wide uppercase text-base-content/80 hover:text-primary">Contact</a>
						</li>
						<li>
							<a href="/rss.xml" class="link-reveal px-1 py-1 font-display text-sm font-semibold tracking-wide uppercase text-base-content/80 hover:text-primary">RSS</a>
						</li>
					</ul>
				</details>
			</nav>
		</div>
	</div>
</header>
