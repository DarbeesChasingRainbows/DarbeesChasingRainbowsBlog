---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import type { CollectionEntry } from 'astro:content';

type Collection = 'blog' | 'field-notes' | 'projects';
type AnyEntry =
	| CollectionEntry<'blog'>
	| CollectionEntry<'field-notes'>
	| CollectionEntry<'projects'>;

// Discriminating union over the three collection schemas: each has slightly
// different optional fields. We surface only the ones used in the footer nav.
type EntryDataLike = {
	featuredImage?: ImageMetadata;
	heroImage?: ImageMetadata;
	imageAlt?: string;
	category?: string;
	location?: string;
};

interface Props {
	collection: Collection;
	prev?: AnyEntry;
	next?: AnyEntry;
	related?: AnyEntry[];
}

const { collection, prev, next, related = [] } = Astro.props;

const sectionLabel: Record<Collection, string> = {
	blog: 'the journal',
	'field-notes': 'the trail log',
	projects: 'the workshop',
};

const indexHref: Record<Collection, string> = {
	blog: '/blog',
	'field-notes': '/field-notes',
	projects: '/projects',
};

function entryHref(c: Collection, id: string) {
	return `/${c}/${id}/`;
}

function entryHero(e: AnyEntry): ImageMetadata | undefined {
	const data = e.data as EntryDataLike;
	return data.featuredImage ?? data.heroImage ?? undefined;
}
---

<aside class="not-prose mt-16">
	<!-- Prev / Next -->
	{
		(prev || next) && (
			<div class="bg-base-content/10 border-base-content/10 grid gap-px border-y sm:grid-cols-2">
				{prev ? (
					<a
						href={entryHref(collection, prev.id)}
						class="group bg-base-100 hover:bg-base-200/60 flex flex-col gap-2 p-6 transition-colors"
					>
						<span class="font-display text-base-content/50 inline-flex items-center gap-1.5 text-[10px] font-bold tracking-[0.22em] uppercase">
							<svg
								xmlns="http://www.w3.org/2000/svg"
								class="h-3 w-3 transition-transform group-hover:-translate-x-1"
								viewBox="0 0 20 20"
								fill="currentColor"
							>
								<path
									fill-rule="evenodd"
									d="M12.707 5.293a1 1 0 010 1.414L9.414 10l3.293 3.293a1 1 0 01-1.414 1.414l-4-4a1 1 0 010-1.414l4-4a1 1 0 011.414 0z"
									clip-rule="evenodd"
								/>
							</svg>
							Previously
						</span>
						<span class="font-editorial text-base-content group-hover:text-primary line-clamp-2 text-xl transition-colors">
							{prev.data.title}
						</span>
					</a>
				) : (
					<div class="bg-base-100" />
				)}
				{next ? (
					<a
						href={entryHref(collection, next.id)}
						class="group bg-base-100 hover:bg-base-200/60 flex flex-col gap-2 p-6 transition-colors sm:items-end sm:text-right"
					>
						<span class="font-display text-base-content/50 inline-flex items-center gap-1.5 text-[10px] font-bold tracking-[0.22em] uppercase">
							Up next
							<svg
								xmlns="http://www.w3.org/2000/svg"
								class="h-3 w-3 transition-transform group-hover:translate-x-1"
								viewBox="0 0 20 20"
								fill="currentColor"
							>
								<path
									fill-rule="evenodd"
									d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z"
									clip-rule="evenodd"
								/>
							</svg>
						</span>
						<span class="font-editorial text-base-content group-hover:text-primary line-clamp-2 text-xl transition-colors">
							{next.data.title}
						</span>
					</a>
				) : (
					<div class="bg-base-100" />
				)}
			</div>
		)
	}

	<!-- Related -->
	{
		related.length > 0 && (
			<div class="mt-14">
				<div class="mb-8 flex items-baseline gap-4">
					<span class="eyebrow">Keep reading · more from {sectionLabel[collection]}</span>
					<span class="border-base-content/15 flex-1 border-t" />
					<a
						href={indexHref[collection]}
						class="link-reveal font-display text-base-content/60 hover:text-primary text-xs font-bold tracking-[0.2em] uppercase"
					>
						All →
					</a>
				</div>
				<div class="grid gap-8 sm:grid-cols-2">
					{related.map((entry) => {
						const hero = entryHero(entry);
						return (
							<a href={`/${entry.collection}/${entry.id}/`} class="group flex items-start gap-4">
								{hero && (
									<figure class="bg-base-200 ring-base-300/60 h-24 w-24 shrink-0 overflow-hidden rounded-xl ring-1 sm:h-28 sm:w-28">
										<Image
											src={hero}
											alt={(entry.data as EntryDataLike).imageAlt ?? entry.data.title}
											width={224}
											height={224}
											class="h-full w-full object-cover transition-transform duration-700 ease-out group-hover:scale-[1.06]"
										/>
									</figure>
								)}
								<div class="min-w-0 flex-1">
									<div class="font-display text-primary mb-1 text-[10px] font-bold tracking-[0.2em] uppercase">
										{(entry.data as EntryDataLike).category ??
											(entry.data as EntryDataLike).location}
									</div>
									<h4 class="font-editorial text-lg leading-tight">
										<span class="title-sweep">{entry.data.title}</span>
									</h4>
									<p class="text-base-content/65 mt-1 line-clamp-2 text-sm">
										{entry.data.description}
									</p>
								</div>
							</a>
						);
					})}
				</div>
			</div>
		)
	}
</aside>
