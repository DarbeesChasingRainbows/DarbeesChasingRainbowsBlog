---
interface Props {
	fieldNotesCount: number;
	blogCount: number;
	projectsCount: number;
}

const { fieldNotesCount, blogCount, projectsCount } = Astro.props;
---

<aside class="lg:col-span-4 space-y-5">
	<!-- IN THIS ISSUE -->
	<div class="rounded-xl border border-base-content/12 bg-base-100 px-5 pt-4 pb-5 shadow-sm">
		<div class="eyebrow mb-4 tracking-[0.22em]">In this issue</div>
		<ul class="space-y-0 font-display font-bold text-sm text-base-content">
			<li class="flex justify-between items-baseline gap-4 border-b border-dashed border-base-content/15 py-2.5">
				<span>Field Notes</span>
				<span class="text-base-content/45 tabular-nums text-xs font-semibold">{fieldNotesCount}</span>
			</li>
			<li class="flex justify-between items-baseline gap-4 border-b border-dashed border-base-content/15 py-2.5">
				<span>Essays &amp; Posts</span>
				<span class="text-base-content/45 tabular-nums text-xs font-semibold">{blogCount}</span>
			</li>
			<li class="flex justify-between items-baseline gap-4 pt-2.5">
				<span>Builds &amp; Projects</span>
				<span class="text-base-content/45 tabular-nums text-xs font-semibold">{projectsCount}</span>
			</li>
		</ul>
	</div>

	<!-- NOW box -->
	<div class="rounded-xl bg-secondary/20 border border-secondary/35 px-5 pt-4 pb-5">
		<div class="eyebrow mb-2 tracking-[0.22em]">Now</div>
		<p class="font-display text-sm font-semibold text-base-content/85 leading-relaxed italic">
			Homeschooling on the road, documenting the honest
			parts of RV life, learning from the places we visit, and
			working toward Kingdom Farm — one lesson, repair,
			field note, and rainbow at a time.
		</p>
	</div>
</aside>
