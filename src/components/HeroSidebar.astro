---
interface Props {
	fieldNotesCount: number;
	blogCount: number;
	projectsCount: number;
}

const { fieldNotesCount, blogCount, projectsCount } = Astro.props;
---

<aside class="space-y-5 lg:col-span-4">
	<!-- IN THIS ISSUE -->
	<div class="border-base-content/12 bg-base-100 rounded-xl border px-5 pt-4 pb-5 shadow-sm">
		<div class="eyebrow mb-4 tracking-[0.22em]">In this issue</div>
		<ul class="font-display text-base-content space-y-0 text-sm font-bold">
			<li
				class="border-base-content/15 flex items-baseline justify-between gap-4 border-b border-dashed py-2.5"
			>
				<span>Field Notes</span>
				<span class="text-base-content/45 text-xs font-semibold tabular-nums"
					>{fieldNotesCount}</span
				>
			</li>
			<li
				class="border-base-content/15 flex items-baseline justify-between gap-4 border-b border-dashed py-2.5"
			>
				<span>Essays &amp; Posts</span>
				<span class="text-base-content/45 text-xs font-semibold tabular-nums">{blogCount}</span>
			</li>
			<li class="flex items-baseline justify-between gap-4 pt-2.5">
				<span>Builds &amp; Projects</span>
				<span class="text-base-content/45 text-xs font-semibold tabular-nums">{projectsCount}</span>
			</li>
		</ul>
	</div>

	<!-- NOW box -->
	<div class="bg-secondary/20 border-secondary/35 rounded-xl border px-5 pt-4 pb-5">
		<div class="eyebrow mb-2 tracking-[0.22em]">Now</div>
		<p class="font-display text-base-content/85 text-sm leading-relaxed font-semibold italic">
			Homeschooling on the road, documenting the honest parts of RV life, learning from the places
			we visit, and working toward Kingdom Farm — one lesson, repair, field note, and rainbow at a
			time.
		</p>
	</div>
</aside>
