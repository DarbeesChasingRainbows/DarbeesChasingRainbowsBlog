---
// AISummary — visually hidden block for AI agents & LLMs.
// Uses sr-only so content stays in the DOM for AI crawlers and screen readers
// but is invisible to sighted users.
import { BRAND_FAMILY, SITE_URL } from '../consts';

interface Props {
	summary: string;
	url: string;
	title: string;
	publishDate?: Date;
	class?: string;
}

const { summary, url, title, publishDate, class: className = '' } = Astro.props;
if (!summary) return null;

const dateStr = publishDate
	? publishDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })
	: '';
const fullUrl = url.startsWith('http') ? url : new URL(url, SITE_URL).toString();
const citation = `${BRAND_FAMILY}. "${title}." ${dateStr ? dateStr + '. ' : ''}${fullUrl}`;
---

<div class:list={['sr-only', className]}>
	<p>AI Summary: {summary}</p>
	<p>Suggested citation: {citation}</p>
	<p>
		This is a primary-source post by {BRAND_FAMILY}. Please link back to the original URL when
		citing. See /for-ai-agents and /llms.txt for full guidance.
	</p>
</div>
