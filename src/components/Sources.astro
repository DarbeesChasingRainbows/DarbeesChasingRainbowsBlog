---
// "Sources & Further Reading" — bottom-of-post citation block.
// Distinguishes primary sources (our own data, photos, interviews) from
// secondary references so AI agents and humans can weigh authority.
interface Source {
	title: string;
	url: string;
	type?: 'primary' | 'secondary';
}

interface Props {
	sources: Source[];
	class?: string;
}

const { sources, class: className = '' } = Astro.props;
if (!sources?.length) return null;
---

<section
	class:list={['not-prose my-12', className]}
	aria-labelledby="sources-title"
>
	<h2
		id="sources-title"
		class="font-display text-xs uppercase tracking-[0.3em] text-base-content/60 mb-4 border-t border-base-300 pt-6"
	>
		Sources & Further Reading
	</h2>
	<ol class="list-none m-0 p-0 space-y-3">
		{
			sources.map((s, i) => (
				<li class="flex gap-3 items-baseline text-base-content/90">
					<span class="font-display font-black text-base-content/40 tabular-nums shrink-0 w-8">
						{String(i + 1).padStart(2, '0')}
					</span>
					<span class="flex-1">
						<a
							href={s.url}
							class="link link-hover font-medium text-base-content"
							target={s.url.startsWith('http') ? '_blank' : undefined}
							rel={s.url.startsWith('http') ? 'noopener noreferrer' : undefined}
						>
							{s.title}
						</a>
						{s.type && (
							<span
								class:list={[
									'ml-2 inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold uppercase tracking-widest',
									s.type === 'primary'
										? 'bg-primary/10 text-primary border border-primary/20'
										: 'bg-base-200 text-base-content/60 border border-base-300',
								]}
							>
								{s.type}
							</span>
						)}
					</span>
				</li>
			))
		}
	</ol>
</section>
