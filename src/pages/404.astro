---
import BaseLayout from '../layouts/BaseLayout.astro';

const exits = [
	{ label: 'Home', href: '/', desc: 'Start fresh from the cover.', tag: '01' },
	{ label: 'Blog', href: '/blog', desc: 'Essays, dispatches, and updates.', tag: '02' },
	{ label: 'Field Notes', href: '/field-notes', desc: 'Real places, written down.', tag: '03' },
	{ label: 'Projects', href: '/projects', desc: 'Things we built.', tag: '04' },
	{ label: 'Kingdom Farm', href: '/kingdom-farm', desc: 'The long-term family vision.', tag: '05' },
	{ label: 'Contact', href: '/contact', desc: 'Say hello.', tag: '06' },
];
---

<BaseLayout title="Page not found" description="The page you were looking for doesn't exist.">
	<section class="mx-auto max-w-7xl px-6 pt-16 pb-12 md:pt-24">
		<div class="grid items-end gap-10 lg:grid-cols-12">
			<div class="lg:col-span-8">
				<div class="mb-6 flex items-center gap-3">
					<span class="bg-accent inline-block h-px w-10"></span>
					<span class="eyebrow text-accent">Error 404 · Off-trail</span>
				</div>
				<h1 class="font-editorial text-base-content text-[clamp(4rem,14vw,11rem)] leading-[0.9]">
					This trail<br />
					<span class="text-accent italic">doesn't go</span><br />
					through.
				</h1>
			</div>
			<div class="lg:border-primary/15 lg:col-span-4 lg:border-l lg:pl-8">
				<p class="text-base-content/70 leading-relaxed">
					The page you were looking for isn't here — maybe a typo, maybe we moved it, maybe it's
					still being written. Pick a way back in below.
				</p>
				<a
					href="/"
					class="bg-primary text-primary-content font-display hover:bg-accent mt-6 inline-flex items-center gap-2 rounded-full px-6 py-3 font-bold tracking-wide transition-colors"
				>
					<svg
						xmlns="http://www.w3.org/2000/svg"
						class="h-4 w-4"
						viewBox="0 0 20 20"
						fill="currentColor"
						><path
							fill-rule="evenodd"
							d="M9.707 16.707a1 1 0 01-1.414 0l-6-6a1 1 0 010-1.414l6-6a1 1 0 011.414 1.414L5.414 9H17a1 1 0 110 2H5.414l4.293 4.293a1 1 0 010 1.414z"
							clip-rule="evenodd"></path></svg
					>
					Take me home
				</a>
			</div>
		</div>
	</section>

	<section class="mx-auto max-w-7xl px-6 pb-24">
		<div class="mb-8 flex items-baseline gap-4">
			<span class="eyebrow">Or wander somewhere</span>
			<span class="border-base-content/15 flex-1 border-t"></span>
		</div>
		<div class="grid gap-x-10 gap-y-2 sm:grid-cols-2 lg:grid-cols-3">
			{
				exits.map((e) => (
					<a
						href={e.href}
						class="group border-base-content/15 hover:border-primary flex items-start gap-5 border-t py-6 transition-colors"
					>
						<span class="font-display text-primary/40 group-hover:text-primary pt-1 text-3xl font-black tracking-tight tabular-nums transition-colors">
							{e.tag}
						</span>
						<div class="flex-1">
							<h3 class="font-editorial mb-1.5 text-2xl">
								<span class="title-sweep">{e.label}</span>
							</h3>
							<p class="text-base-content/65 text-sm leading-relaxed">{e.desc}</p>
						</div>
						<svg
							xmlns="http://www.w3.org/2000/svg"
							class="text-base-content/30 group-hover:text-primary mt-2 h-4 w-4 transition-all group-hover:translate-x-1"
							viewBox="0 0 20 20"
							fill="currentColor"
						>
							<path
								fill-rule="evenodd"
								d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z"
								clip-rule="evenodd"
							/>
						</svg>
					</a>
				))
			}
		</div>
	</section>
</BaseLayout>
