---
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import NewsletterSignup from '../../components/NewsletterSignup.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { getBlogPosts, getCategories } from '../../utils/getPosts';

const posts = await getBlogPosts();
const categories = getCategories(posts);
const featured = posts[0];
const rest = posts.slice(1);
const featuredHero = featured?.data.featuredImage ?? featured?.data.heroImage;
const featuredHeroImage = featuredHero && typeof featuredHero === 'object' && 'src' in featuredHero ? featuredHero : undefined;
---

<BaseLayout
	title="Blog"
	description="Family updates, RV life, homeschool, faith, and useful things we've learned on the road."
>
	<!-- ========= Masthead ========= -->
	<section class="mx-auto max-w-7xl px-6 pt-10 pb-8 md:pt-14">
		<Breadcrumbs class="mb-6" items={[{ label: 'Home', href: '/' }, { label: 'Blog' }]} />
		<div class="grid items-end gap-8 lg:grid-cols-12">
			<div class="lg:col-span-8">
				<div class="mb-6 flex items-center gap-3">
					<span class="bg-primary inline-block h-px w-10"></span>
					<span class="eyebrow">The Journal</span>
				</div>
				<h1 class="font-editorial text-[clamp(3rem,8vw,7rem)]">
					Notes from <span class="text-accent italic">the road</span>.
				</h1>
				<p class="text-base-content/70 mt-6 max-w-xl text-lg leading-relaxed">
					Family updates, RV life, homeschool, faith, and useful things we've learned along the way.
				</p>
			</div>
			<div class="lg:border-primary/15 lg:col-span-4 lg:border-l lg:pl-8">
				<div class="eyebrow mb-3">Filed under</div>
				<div class="font-display text-base-content/75 flex flex-wrap gap-x-4 gap-y-1 font-bold">
					{
						categories.map((c, i) => (
							<>
								{i > 0 && <span class="text-base-content/30">·</span>}
								<a
									href={`/category/${encodeURIComponent(c)}/`}
									class="link-reveal hover:text-primary"
									data-filter-link={c}
								>
									{c}
								</a>
							</>
						))
					}
				</div>
				<a
					href="/rss.xml"
					class="font-display text-base-content/55 hover:text-primary mt-4 inline-flex items-center gap-1.5 text-xs font-bold tracking-[0.2em] uppercase"
				>
					<svg
						xmlns="http://www.w3.org/2000/svg"
						class="h-3.5 w-3.5"
						viewBox="0 0 20 20"
						fill="currentColor"
						><path
							d="M3.429 2.5A1.429 1.429 0 002 3.929v12.142A1.429 1.429 0 003.429 17.5h13.142A1.429 1.429 0 0018 16.071V3.93A1.429 1.429 0 0016.571 2.5H3.43zM5 7a1 1 0 011-1 7 7 0 017 7 1 1 0 11-2 0 5 5 0 00-5-5 1 1 0 01-1-1zm0 4a1 1 0 011-1 3 3 0 013 3 1 1 0 11-2 0 1 1 0 00-1-1 1 1 0 01-1-1zm1 3a1 1 0 100 2 1 1 0 000-2z"
						></path></svg
					>
					Subscribe via RSS
				</a>
			</div>
		</div>
	</section>

	<!-- ========= Filter bar (client-side) ========= -->
	{
		posts.length > 0 && (
			<section
				id="blog-filter-bar"
				class="sticky top-[88px] z-20 mx-auto mb-2 max-w-7xl px-6 py-3"
				data-filter-bar
			>
				<div class="border-primary/15 bg-base-100/90 flex items-center gap-3 rounded-full border px-4 py-2 shadow-sm backdrop-blur-md">
					<span class="eyebrow hidden shrink-0 sm:inline">Filter</span>
					<div class="no-scrollbar -my-1 flex flex-1 items-center gap-1.5 overflow-x-auto py-1">
						<button type="button" data-filter-chip="" class="filter-chip active">
							All
						</button>
						{categories.map((c) => (
							<button type="button" data-filter-chip={c} class="filter-chip">
								{c}
							</button>
						))}
					</div>
					<button
						type="button"
						data-filter-clear
						style="display:none"
						class="font-display text-base-content/60 hover:text-primary hover:border-primary/30 shrink-0 items-center gap-1 rounded-full border border-transparent px-3 py-1 text-[10px] font-bold tracking-[0.18em] uppercase"
					>
						<svg
							xmlns="http://www.w3.org/2000/svg"
							class="h-3 w-3"
							viewBox="0 0 20 20"
							fill="currentColor"
						>
							<path
								fill-rule="evenodd"
								d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z"
								clip-rule="evenodd"
							/>
						</svg>
						Clear
					</button>
				</div>
			</section>
		)
	}

	{
		posts.length === 0 ? (
			<section class="mx-auto max-w-3xl px-6 py-24 text-center">
				<p class="font-editorial text-base-content/40 text-3xl">No posts yet. Check back soon.</p>
			</section>
		) : (
			<>
				{/* Featured */}
				{featured && (
					<section
						class="mx-auto max-w-7xl px-6 pt-6 pb-12"
						data-filter-item
						data-category={featured.data.category}
						data-tags={(featured.data.tags ?? []).join('|')}
					>
						<div class="mb-8 flex items-baseline gap-4">
							<span class="eyebrow">Most recent</span>
							<span class="border-base-content/15 flex-1 border-t" />
						</div>
						<a
							href={`/blog/${featured.id}/`}
							class="group grid items-center gap-8 lg:grid-cols-12 lg:gap-12"
						>
							{featuredHeroImage && (
								<figure class="bg-base-200 ring-base-300/60 relative aspect-4/3 overflow-hidden rounded-3xl ring-1 lg:col-span-7 lg:aspect-5/4">
									<Image
										src={featuredHeroImage}
										alt={featured.data.title}
										width={1400}
										height={1100}
										class="h-full w-full object-cover transition-transform duration-700 ease-out group-hover:scale-[1.04]"
									/>
									<span class="bg-base-100/95 font-display text-primary absolute top-4 left-4 inline-flex items-center gap-2 rounded-full px-3 py-1.5 text-[11px] font-bold tracking-[0.18em] uppercase shadow-md backdrop-blur">
										{featured.data.category}
									</span>
								</figure>
							)}
							<div class={featuredHeroImage ? 'lg:col-span-5' : 'max-w-3xl lg:col-span-12'}>
								<div class="font-display text-base-content/55 mb-4 flex items-center gap-2 text-[11px] font-bold tracking-[0.2em] uppercase">
									<FormattedDate date={featured.data.pubDate} />
									<span>·</span>
									<span>{featured.data.category}</span>
								</div>
								<h2 class="font-editorial mb-5 text-4xl md:text-5xl">
									<span class="title-sweep">{featured.data.title}</span>
								</h2>
								<p class="text-base-content/70 mb-6 text-lg leading-relaxed">
									{featured.data.description}
								</p>
								<span class="font-display text-primary inline-flex items-center gap-2 font-bold tracking-wide transition-all group-hover:gap-3">
									Read the full piece
									<svg
										xmlns="http://www.w3.org/2000/svg"
										class="h-4 w-4"
										viewBox="0 0 20 20"
										fill="currentColor"
									>
										<path
											fill-rule="evenodd"
											d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z"
											clip-rule="evenodd"
										/>
									</svg>
								</span>
							</div>
						</a>
					</section>
				)}

				{/* Archive grid */}
				{rest.length > 0 && (
					<section class="mx-auto max-w-7xl px-6 pt-12 pb-16 md:pt-20">
						<div class="mb-10 flex items-baseline gap-4">
							<span class="eyebrow">The Archive</span>
							<span class="border-base-content/15 flex-1 border-t" />
							<span class="font-display text-base-content/50 text-xs font-bold tracking-[0.2em] uppercase tabular-nums">
								{rest.length} posts
							</span>
						</div>
						<div class="grid gap-x-8 gap-y-12 sm:grid-cols-2 lg:grid-cols-3" data-filter-grid>
							{rest.map((post) => (
								<div
									data-filter-item
									data-category={post.data.category}
									data-tags={(post.data.tags ?? []).join('|')}
								>
									<PostCard kind="blog" entry={post} />
								</div>
							))}
						</div>
						<p
							data-filter-empty
							style="display:none"
							class="font-editorial text-base-content/40 py-16 text-center text-2xl"
						>
							No posts in this category yet.{' '}
							<button
								type="button"
								data-filter-clear-inline
								class="text-primary underline underline-offset-4"
							>
								Show all posts
							</button>
							.
						</p>
					</section>
				)}
			</>
		)
	}

	<section class="mx-auto max-w-5xl px-6 pt-12 pb-16">
		<div
			class="border-primary/20 bg-base-100 relative overflow-hidden rounded-4xl border p-10 md:p-14"
		>
			<div
				aria-hidden="true"
				class="bg-secondary/30 absolute -top-20 -right-20 h-72 w-72 rounded-full blur-3xl"
			>
			</div>
			<div
				aria-hidden="true"
				class="bg-primary/15 absolute -bottom-24 -left-24 h-72 w-72 rounded-full blur-3xl"
			>
			</div>
			<div class="relative">
				<NewsletterSignup />
			</div>
		</div>
	</section>
</BaseLayout>

<style is:global>
	.filter-chip {
		display: inline-flex;
		align-items: center;
		padding: 0.4rem 0.85rem;
		border-radius: 9999px;
		font-family: var(--font-display);
		font-size: 0.7rem;
		font-weight: 700;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		color: oklch(from var(--color-base-content) l c h / 0.65);
		white-space: nowrap;
		transition:
			background-color 0.2s,
			color 0.2s;
	}
	.filter-chip:hover {
		color: var(--color-primary);
	}
	.filter-chip.active {
		background-color: var(--color-primary);
		color: var(--color-primary-content);
	}
	.no-scrollbar::-webkit-scrollbar {
		display: none;
	}
	.no-scrollbar {
		scrollbar-width: none;
	}
</style>

<script>
	type FilterEl = HTMLElement & { dataset: DOMStringMap };

	function applyFilter(category: string, tag: string | null) {
		const items = document.querySelectorAll<FilterEl>('[data-filter-item]');
		let shownInArchive = 0;
		items.forEach((el) => {
			const cat = el.dataset.category ?? '';
			const tags = (el.dataset.tags ?? '').split('|').filter(Boolean);
			const matchCat = !category || cat === category;
			const matchTag = !tag || tags.includes(tag);
			const visible = matchCat && matchTag;
			el.style.display = visible ? '' : 'none';
			if (visible && el.closest('[data-filter-grid]')) shownInArchive++;
		});

		// Chips
		document.querySelectorAll<HTMLButtonElement>('[data-filter-chip]').forEach((btn) => {
			btn.classList.toggle('active', (btn.dataset.filterChip ?? '') === category);
		});

		// Clear button
		const clearBtn = document.querySelector<HTMLButtonElement>('[data-filter-clear]');
		if (clearBtn) clearBtn.style.display = category || tag ? 'inline-flex' : 'none';

		// Empty state
		const empty = document.querySelector<HTMLElement>('[data-filter-empty]');
		const grid = document.querySelector<HTMLElement>('[data-filter-grid]');
		if (empty && grid) {
			const isFiltered = !!(category || tag);
			empty.style.display = isFiltered && shownInArchive === 0 ? 'block' : 'none';
			grid.style.display = isFiltered && shownInArchive === 0 ? 'none' : '';
		}
	}

	function setFilter(category: string, tag: string | null, push = true) {
		const url = new URL(window.location.href);
		if (category) url.searchParams.set('category', category);
		else url.searchParams.delete('category');
		if (tag) url.searchParams.set('tag', tag);
		else url.searchParams.delete('tag');
		if (push) history.pushState({ category, tag }, '', url.toString());
		applyFilter(category, tag);
	}

	function init() {
		const params = new URLSearchParams(window.location.search);
		const category = params.get('category') ?? '';
		const tag = params.get('tag');
		applyFilter(category, tag);

		document.querySelectorAll<HTMLButtonElement>('[data-filter-chip]').forEach((btn) => {
			btn.addEventListener('click', () => setFilter(btn.dataset.filterChip ?? '', null));
		});
		document.querySelectorAll<HTMLAnchorElement>('[data-filter-link]').forEach((link) => {
			link.addEventListener('click', (e) => {
				e.preventDefault();
				setFilter(link.dataset.filterLink ?? '', null);
				window.scrollTo({
					top: document.getElementById('blog-filter-bar')?.offsetTop ?? 0,
					behavior: 'smooth',
				});
			});
		});
		const clearBtn = document.querySelector<HTMLButtonElement>('[data-filter-clear]');
		clearBtn?.addEventListener('click', () => setFilter('', null));
		const inlineClear = document.querySelector<HTMLButtonElement>('[data-filter-clear-inline]');
		inlineClear?.addEventListener('click', () => setFilter('', null));

		window.addEventListener('popstate', () => {
			const p = new URLSearchParams(window.location.search);
			applyFilter(p.get('category') ?? '', p.get('tag'));
		});
	}

	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', init);
	} else {
		init();
	}
</script>
