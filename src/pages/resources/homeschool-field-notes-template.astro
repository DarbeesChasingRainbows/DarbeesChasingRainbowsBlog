---
// Homeschool Field Notes — printable template
// Standalone, print-optimized page. Hit Cmd/Ctrl+P → "Save as PDF" or print
// to paper. Designed to fit on a single US Letter / A4 page in portrait.
import '../../styles/global.css';
import { SITE_TITLE } from '../../consts';

const title = `Homeschool Field Notes Template · ${SITE_TITLE}`;
const description =
	'Free printable: three things we saw, one we heard, one we wondered, one we learned, plus a sketch box. From Darbees Chasing Rainbows.';
---

<!doctype html>
<html lang="en" data-theme="forest">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width,initial-scale=1" />
		<title>{title}</title>
		<meta name="description" content={description} />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
	</head>
	<body class="bg-base-200 print:bg-white">
		<!-- Screen-only toolbar -->
		<div class="print:hidden bg-base-100 border-b border-base-300 sticky top-0 z-10">
			<div class="mx-auto max-w-4xl px-4 py-3 flex items-center justify-between gap-4">
				<a href="/resources" class="link link-hover text-sm flex items-center gap-1">
					<svg
						xmlns="http://www.w3.org/2000/svg"
						class="h-4 w-4"
						viewBox="0 0 20 20"
						fill="currentColor"
					>
						<path
							fill-rule="evenodd"
							d="M12.707 5.293a1 1 0 010 1.414L9.414 10l3.293 3.293a1 1 0 01-1.414 1.414l-4-4a1 1 0 010-1.414l4-4a1 1 0 011.414 0z"
							clip-rule="evenodd"></path>
					</svg>
					<span>Back to resources</span>
				</a>
				<div class="flex items-center gap-2">
					<span class="hidden sm:inline text-xs text-base-content/60">
						Tip: Print → "Save as PDF" for a clean copy
					</span>
					<button
						type="button"
						id="print-btn"
						class="btn btn-primary btn-sm gap-2"
					>
						<svg
							xmlns="http://www.w3.org/2000/svg"
							class="h-4 w-4"
							viewBox="0 0 20 20"
							fill="currentColor"
						>
							<path
								fill-rule="evenodd"
								d="M5 4v3H4a2 2 0 00-2 2v3a2 2 0 002 2h1v2a2 2 0 002 2h6a2 2 0 002-2v-2h1a2 2 0 002-2V9a2 2 0 00-2-2h-1V4a2 2 0 00-2-2H7a2 2 0 00-2 2zm8 0H7v3h6V4zm0 8H7v4h6v-4z"
								clip-rule="evenodd"></path>
						</svg>
						Print this page
					</button>
				</div>
			</div>
		</div>

		<main class="mx-auto max-w-4xl px-4 py-6 print:p-0 print:max-w-none">
			<div
				class="bg-white rounded-2xl shadow-sm print:shadow-none print:rounded-none border border-base-300 print:border-0 p-8 md:p-12 print:p-6 print-page"
			>
				<!-- Header -->
				<header class="mb-4 pb-3 border-b-2 border-primary/20">
					<div class="flex items-start justify-between gap-4">
						<div>
							<p
								class="font-display text-[10px] uppercase tracking-[0.3em] text-primary mb-1"
							>
								Field Notes
							</p>
							<h1
								class="font-display text-2xl md:text-3xl font-extrabold leading-none tracking-tight text-base-content"
							>
								Today I noticed…
							</h1>
						</div>
						<div class="text-right shrink-0 hidden sm:block">
							<p class="font-display text-[9px] uppercase tracking-widest text-base-content/50">
								darbeeschasingrainbows.com
							</p>
						</div>
					</div>

					<dl class="mt-5 grid grid-cols-3 gap-4 text-sm">
						<div>
							<dt
								class="font-display text-[9px] uppercase tracking-widest text-base-content/60 mb-1"
							>
								Name
							</dt>
							<dd class="border-b-2 border-base-content/30 h-7"></dd>
						</div>
						<div>
							<dt
								class="font-display text-[9px] uppercase tracking-widest text-base-content/60 mb-1"
							>
								Date
							</dt>
							<dd class="border-b-2 border-base-content/30 h-7"></dd>
						</div>
						<div>
							<dt
								class="font-display text-[9px] uppercase tracking-widest text-base-content/60 mb-1"
							>
								Where
							</dt>
							<dd class="border-b-2 border-base-content/30 h-7"></dd>
						</div>
					</dl>
				</header>

				<!-- 3 things we saw -->
				<section class="mb-4 avoid-break">
					<div class="flex items-baseline gap-2 mb-2">
						<span
							class="badge-icon inline-flex items-center justify-center w-6 h-6 rounded-full bg-primary text-primary-content font-display font-black text-xs"
							>3</span
						>
						<h2 class="font-display text-base font-extrabold m-0">Things I saw</h2>
					</div>
					<ol class="list-none p-0 m-0 space-y-2">
						{
							[1, 2, 3].map((n) => (
								<li class="flex items-start gap-3">
									<span class="font-display font-black text-primary/60 tabular-nums shrink-0 w-5 pt-1 text-sm">
										{n}.
									</span>
									<span class="flex-1 border-b border-base-content/30 h-7" />
								</li>
							))
						}
					</ol>
				</section>

				<!-- Heard / Wondered / Learned -->
				<section class="mb-5 grid gap-3 avoid-break">
					<div>
						<div class="flex items-baseline gap-2 mb-1">
							<span
								class="badge-icon inline-flex items-center justify-center w-6 h-6 rounded-full bg-secondary text-secondary-content font-display font-black text-xs"
								>♪</span
							>
							<h2 class="font-display text-sm font-extrabold m-0">
								One thing I heard
							</h2>
						</div>
						<div class="border-b border-base-content/30 h-7"></div>
					</div>

					<div>
						<div class="flex items-baseline gap-2 mb-1">
							<span
								class="badge-icon inline-flex items-center justify-center w-6 h-6 rounded-full bg-accent text-accent-content font-display font-black text-xs"
								>?</span
							>
							<h2 class="font-display text-sm font-extrabold m-0">
								One thing I wondered
							</h2>
						</div>
						<div class="border-b border-base-content/30 h-7"></div>
					</div>

					<div>
						<div class="flex items-baseline gap-2 mb-1">
							<span
								class="badge-icon inline-flex items-center justify-center w-6 h-6 rounded-full bg-primary text-primary-content font-display font-black text-xs"
								>★</span
							>
							<h2 class="font-display text-sm font-extrabold m-0">
								One thing I learned
							</h2>
						</div>
						<div class="border-b border-base-content/30 h-7"></div>
					</div>
				</section>

				<!-- Sketch box -->
				<section class="avoid-break">
					<div class="flex items-baseline gap-2 mb-2">
						<span
							class="badge-icon inline-flex items-center justify-center w-6 h-6 rounded-full bg-base-content text-base-100 font-display font-black text-xs"
							>✎</span
						>
						<h2 class="font-display text-base font-extrabold m-0">
							Sketch what I saw
						</h2>
					</div>
					<div
						class="border-2 border-base-content/30 rounded-xl bg-base-100 sketch-box"
					>
					</div>
				</section>

				<!-- Footer -->
				<footer class="mt-4 pt-3 border-t border-base-300 flex items-center justify-between text-[10px] text-base-content/50">
					<span>Made by The Darbees · darbeeschasingrainbows.com</span>
					<span>Free to print & share</span>
				</footer>
			</div>
		</main>

		<!-- Screen-only credit / link back -->
		<div class="print:hidden mx-auto max-w-4xl px-4 pb-12 text-center">
			<p class="text-sm text-base-content/60">
				Want more like this?
				<a class="link" href="/resources">See all resources</a>
				·
				<a class="link" href="/homeschool">Homeschool philosophy</a>
			</p>
		</div>

		<style>
			.sketch-box {
				height: 28rem;
			}
			/* Force color rendering for circular icon badges so they don't print
			   as plain outlines in WebKit/Chromium/Firefox. */
			.badge-icon {
				-webkit-print-color-adjust: exact;
				print-color-adjust: exact;
			}
			@media print {
				@page {
					size: letter portrait;
					margin: 0.4in;
				}
				html,
				body {
					background: white !important;
					-webkit-print-color-adjust: exact;
					print-color-adjust: exact;
				}
				.print-page {
					box-shadow: none !important;
					border: none !important;
					padding: 0 !important;
				}
				/* Keep each section together on one page. */
				.avoid-break {
					break-inside: avoid;
					page-break-inside: avoid;
				}
				/* Slightly shorter sketch box guarantees the whole sheet fits on
				   one Letter page even with default browser print headers. */
				.sketch-box {
					height: 3.6in;
				}
			}
		</style>

		<script>
			document.getElementById('print-btn')?.addEventListener('click', () => {
				window.print();
			});
		</script>
	</body>
</html>
