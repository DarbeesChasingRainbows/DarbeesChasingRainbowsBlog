---
import BaseLayout from '../layouts/BaseLayout.astro';
import NewsletterSignup from '../components/NewsletterSignup.astro';
import { getBlogPosts } from '../utils/getPosts';
import Departments from '../components/Departments.astro';

const allBlog = await getBlogPosts();

const departments = [
	{ title: 'Field Notes', href: '/field-notes', tag: '01', description: 'Hikes, historic sites, nature studies, and homeschool field trips.' },
	{ title: 'RV Life', href: '/rv-life', tag: '02', description: "The honest road between the house that wasn't forever and the roots we're working toward." },
	{ title: 'Homeschool', href: '/homeschool', tag: '03', description: 'How travel, projects, and faith shape what we learn together.' },
	{ title: 'Projects & Builds', href: '/projects', tag: '04', description: 'DIY, RV automation, and useful things we ship and document.' },
	{ title: 'Kingdom Farm', href: '/kingdom-farm', tag: '05', description: 'The long-term family vision: regenerative food, hospitality, and deeper roots.' },
	{ title: 'Faith & Reflections', href: '/category/Faith%20%26%20Reflections/', tag: '06', description: 'Quiet thoughts on faith, family, and ordinary days.' },
	{ title: 'Darbees Bookshelf', href: '/bookshelf', tag: '07', description: "Family book reviews — Dad's take, Mom's take, kids' take. Christian discernment for every age." },
	{ title: 'Resources', href: '/resources', tag: '08', description: 'Free templates, field note printables, gear lists, and project guides.' },
];

const featuredPost = allBlog[0];
const recentPosts = allBlog.slice(1, 7);
---

<BaseLayout>
	<!-- ========= HERO ========= -->
	<section class="mx-auto max-w-4xl px-6 py-16 md:py-24 text-center">
		<h1 class="font-editorial text-5xl md:text-6xl font-bold text-base-content mb-6">
			Chasing <span class="text-accent italic">Rainbows</span>, Building the <span class="text-primary">Kingdom Farm</span>
		</h1>
		<p class="text-base-content/70 text-lg md:text-xl max-w-2xl mx-auto leading-relaxed">
			A slow, honest record of family on the road — RV life, faith, homeschool field trips, useful builds, and the long road toward a piece of land worth tending.
		</p>
	</section>

	<!-- ========= FEATURED POST ========= -->
	{featuredPost && (
		<section class="mx-auto max-w-5xl px-6 pb-12">
			<a href={`/blog/${featuredPost.id}/`} class="group block">
				<article class="bg-base-200 rounded-2xl p-8 md:p-12 hover:bg-base-200/80 transition-colors">
					<div class="flex items-center gap-3 mb-4">
						<span class="badge badge-primary badge-lg">{featuredPost.data.category}</span>
						<span class="text-base-content/50 text-sm">
							{featuredPost.data.pubDate.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
						</span>
					</div>
					<h2 class="font-editorial text-3xl md:text-4xl font-bold text-base-content group-hover:text-primary transition-colors mb-4">
						{featuredPost.data.title}
					</h2>
					<p class="text-base-content/70 text-lg leading-relaxed">
						{featuredPost.data.description}
					</p>
				</article>
			</a>
		</section>
	)}

	<!-- ========= RECENT POSTS GRID ========= -->
	<section class="mx-auto max-w-6xl px-6 pb-16">
		<h3 class="font-display text-sm font-bold tracking-widest uppercase text-base-content/50 mb-8">
			Recent Posts
		</h3>
		<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
			{recentPosts.map((post) => (
				<a href={`/blog/${post.id}/`} class="group">
					<article class="bg-base-100 border border-base-content/10 rounded-xl p-6 hover:border-primary/30 hover:shadow-lg transition-all h-full flex flex-col">
						<span class="badge badge-ghost badge-sm mb-3">{post.data.category}</span>
						<h4 class="font-editorial text-xl font-semibold text-base-content group-hover:text-primary transition-colors mb-2">
							{post.data.title}
						</h4>
						<p class="text-base-content/60 text-sm leading-relaxed line-clamp-3 flex-1">
							{post.data.description}
						</p>
						<span class="text-base-content/40 text-xs mt-4">
							{post.data.pubDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
						</span>
					</article>
				</a>
			))}
		</div>
	</section>

	<!-- ========= DEPARTMENTS ========= -->
	<Departments departments={departments} />

	<!-- ========= Newsletter ========= -->
	<section id="newsletter" class="mx-auto max-w-5xl px-6 pt-16 pb-16 md:pt-24">
		<div class="border-primary/15 bg-base-100 relative overflow-hidden rounded-3xl border p-10 md:p-14">
			<div aria-hidden="true" class="bg-secondary/15 absolute -top-24 -right-16 h-56 w-56 rounded-full blur-3xl"></div>
			<div class="relative">
				<NewsletterSignup />
			</div>
		</div>
	</section>
</BaseLayout>
