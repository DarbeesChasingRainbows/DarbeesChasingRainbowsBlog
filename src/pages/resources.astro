---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
	title="Resources"
	description="Templates, gear lists, code, and printables. A small library of useful things, growing slowly."
>
	<article class="mx-auto max-w-3xl px-4 py-16 md:py-24">
		<!-- Page Header -->
		<div class="mb-12 text-center md:mb-16">
			<div
				class="bg-primary/10 text-primary mb-6 inline-flex h-16 w-16 items-center justify-center rounded-2xl"
			>
				<svg
					xmlns="http://www.w3.org/2000/svg"
					class="h-8 w-8"
					viewBox="0 0 20 20"
					fill="currentColor"
				>
					<path
						fill-rule="evenodd"
						d="M4 4a2 2 0 012-2h4.586A2 2 0 0112 2.586L15.414 6A2 2 0 0116 7.414V16a2 2 0 01-2 2H6a2 2 0 01-2-2V4zm2 6a1 1 0 011-1h6a1 1 0 110 2H7a1 1 0 01-1-1zm1 3a1 1 0 100 2h6a1 1 0 100-2H7z"
						clip-rule="evenodd"></path>
				</svg>
			</div>
			<h1 class="font-display mb-4 text-4xl font-extrabold md:text-5xl">Resources</h1>
			<p class="text-base-content/70 mx-auto max-w-2xl text-lg md:text-xl">
				A small library of useful things — templates, gear lists, code, and printables.
			</p>
		</div>

		<div class="grid gap-5">
			<div
				class="border-primary/20 bg-primary/5 rounded-2xl border p-6 shadow-sm transition-shadow hover:shadow-md"
			>
				<div class="flex items-start gap-4">
					<div
						class="bg-primary/10 text-primary inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-xl"
					>
						<svg
							xmlns="http://www.w3.org/2000/svg"
							class="h-5 w-5"
							viewBox="0 0 20 20"
							fill="currentColor"
						>
							<path
								fill-rule="evenodd"
								d="M12 2a1 1 0 01.894.553l.894 1.789 2 .291a1 1 0 01.554 1.706l-1.447 1.41.342 1.99a1 1 0 01-1.451 1.054L12 9.854l-1.786.939a1 1 0 01-1.451-1.054l.342-1.99-1.447-1.41a1 1 0 01.554-1.706l2-.291.894-1.789A1 1 0 0112 2zM5 12a1 1 0 011 1v1h1a1 1 0 110 2H6v1a1 1 0 11-2 0v-1H3a1 1 0 110-2h1v-1a1 1 0 011-1z"
								clip-rule="evenodd"></path>
						</svg>
					</div>
					<div class="flex-1">
						<h2 class="font-display mb-1 text-lg font-bold">Family Field Guide</h2>
						<p class="text-base-content/70 mb-3 text-sm">
							A map for new readers: choose where to begin if you want to build a more faithful,
							intentional family life under real constraints.
						</p>
						<a
							href="/resources/family-field-guide"
							class="text-primary inline-flex items-center gap-1 text-sm font-medium hover:underline"
						>
							<span>Open the guide</span>
							<svg
								xmlns="http://www.w3.org/2000/svg"
								class="h-4 w-4"
								viewBox="0 0 20 20"
								fill="currentColor"
							>
								<path
									fill-rule="evenodd"
									d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z"
									clip-rule="evenodd"></path>
							</svg>
						</a>
					</div>
				</div>
			</div>

			<div
				class="border-base-300 bg-base-100 rounded-2xl border p-6 shadow-sm transition-shadow hover:shadow-md"
			>
				<div class="flex items-start gap-4">
					<div
						class="bg-primary/10 text-primary inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-xl"
					>
						<svg
							xmlns="http://www.w3.org/2000/svg"
							class="h-5 w-5"
							viewBox="0 0 20 20"
							fill="currentColor"
						>
							<path
								d="M9 4.804A7.968 7.968 0 005.5 4c-1.255 0-2.443.29-3.5.804v10A7.969 7.969 0 015.5 14c1.669 0 3.218.51 4.5 1.385A7.962 7.962 0 0114.5 14c1.255 0 2.443.29 3.5.804v-10A7.968 7.968 0 0014.5 4c-1.255 0-2.443.29-3.5.804V12a1 1 0 11-2 0V4.804z"
							></path>
						</svg>
					</div>
					<div class="flex-1">
						<h2 class="font-display mb-1 text-lg font-bold">Homeschool field notes template</h2>
						<p class="text-base-content/70 mb-3 text-sm">
							A simple printable for kids: three things we saw, one thing we heard, one thing we
							wondered, one thing we learned, plus a sketch box.
						</p>
						<a
							href="/resources/homeschool-field-notes-template"
							class="text-primary inline-flex items-center gap-1 text-sm font-medium hover:underline"
						>
							<span>Open & print</span>
							<svg
								xmlns="http://www.w3.org/2000/svg"
								class="h-4 w-4"
								viewBox="0 0 20 20"
								fill="currentColor"
							>
								<path
									fill-rule="evenodd"
									d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z"
									clip-rule="evenodd"></path>
							</svg>
						</a>
					</div>
				</div>
			</div>

			<div
				class="border-base-300 bg-base-100 rounded-2xl border p-6 shadow-sm transition-shadow hover:shadow-md"
			>
				<div class="flex items-start gap-4">
					<div
						class="bg-primary/10 text-primary inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-xl"
					>
						<svg
							xmlns="http://www.w3.org/2000/svg"
							class="h-5 w-5"
							viewBox="0 0 20 20"
							fill="currentColor"
						>
							<path
								fill-rule="evenodd"
								d="M11.49 3.17c-.38-1.56-2.6-1.56-2.98 0a1.532 1.532 0 01-2.286.948c-1.372-.836-2.942.734-2.106 2.106.54.886.061 2.042-.947 2.287-1.561.379-1.561 2.6 0 2.978a1.532 1.532 0 01.947 2.287c-.836 1.372.734 2.942 2.106 2.106a1.532 1.532 0 012.287.947c.379 1.561 2.6 1.561 2.978 0a1.533 1.533 0 012.287-.947c1.372.836 2.942-.734 2.106-2.106a1.533 1.533 0 01.947-2.287c1.561-.379 1.561-2.6 0-2.978a1.532 1.532 0 01-.947-2.287c.836-1.372-.734-2.942-2.106-2.106a1.532 1.532 0 01-2.287-.947zM10 13a3 3 0 100-6 3 3 0 000 6z"
								clip-rule="evenodd"></path>
						</svg>
					</div>
					<div class="flex-1">
						<h2 class="font-display mb-1 text-lg font-bold">RV project parts lists</h2>
						<p class="text-base-content/70 mb-3 text-sm">
							Searchable index of every parts list from our project posts.
						</p>
						<a
							href="/projects"
							class="text-primary inline-flex items-center gap-1 text-sm font-medium hover:underline"
						>
							<span>Browse projects</span>
							<svg
								xmlns="http://www.w3.org/2000/svg"
								class="h-4 w-4"
								viewBox="0 0 20 20"
								fill="currentColor"
							>
								<path
									fill-rule="evenodd"
									d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z"
									clip-rule="evenodd"></path>
							</svg>
						</a>
					</div>
				</div>
			</div>

			<div
				class="border-base-300 bg-base-100 rounded-2xl border p-6 shadow-sm transition-shadow hover:shadow-md"
			>
				<div class="flex items-start gap-4">
					<div
						class="bg-primary/10 text-primary inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-xl"
					>
						<svg
							xmlns="http://www.w3.org/2000/svg"
							class="h-5 w-5"
							viewBox="0 0 20 20"
							fill="currentColor"
						>
							<path
								d="M9 4.804A7.968 7.968 0 005.5 4c-1.255 0-2.443.29-3.5.804v10A7.969 7.969 0 015.5 14c1.669 0 3.218.51 4.5 1.385A7.962 7.962 0 0114.5 14c1.255 0 2.443.29 3.5.804v-10A7.968 7.968 0 0014.5 4c-1.255 0-2.443.29-3.5.804V12a1 1 0 11-2 0V4.804z"
							></path>
						</svg>
					</div>
					<div class="flex-1">
						<h2 class="font-display mb-1 text-lg font-bold">Recommended gear</h2>
						<p class="text-base-content/70 mb-3 text-sm">
							What we actually use, with honest notes on what's worth it and what isn't.
						</p>
						<span class="badge badge-warning badge-soft text-xs">Coming soon</span>
					</div>
				</div>
			</div>

			<div
				class="border-base-300 bg-base-100 rounded-2xl border p-6 shadow-sm transition-shadow hover:shadow-md"
			>
				<div class="flex items-start gap-4">
					<div
						class="bg-primary/10 text-primary inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-xl"
					>
						<svg
							xmlns="http://www.w3.org/2000/svg"
							class="h-5 w-5"
							viewBox="0 0 20 20"
							fill="currentColor"
						>
							<path
								fill-rule="evenodd"
								d="M12.316 3.051a1 1 0 01.633 1.265l-4 12a1 1 0 11-1.898-.632l4-12a1 1 0 011.265-.633zM5.707 6.293a1 1 0 010 1.414L3.414 10l2.293 2.293a1 1 0 11-1.414 1.414l-3-3a1 1 0 010-1.414l3-3a1 1 0 011.414 0zm8.586 0a1 1 0 011.414 0l3 3a1 1 0 010 1.414l-3 3a1 1 0 11-1.414-1.414L16.586 10l-2.293-2.293a1 1 0 010-1.414z"
								clip-rule="evenodd"></path>
						</svg>
					</div>
					<div class="flex-1">
						<h2 class="font-display mb-1 text-lg font-bold">GitHub repos</h2>
						<p class="text-base-content/70 mb-3 text-sm">
							Open-source code from projects on the blog. Pull requests welcome.
						</p>
						<a
							href="https://github.com/darbeeschasingrainbows"
							target="_blank"
							rel="noopener"
							class="text-primary inline-flex items-center gap-1 text-sm font-medium hover:underline"
						>
							<span>View on GitHub</span>
							<svg
								xmlns="http://www.w3.org/2000/svg"
								class="h-4 w-4"
								viewBox="0 0 20 20"
								fill="currentColor"
							>
								<path
									fill-rule="evenodd"
									d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z"
									clip-rule="evenodd"></path>
							</svg>
						</a>
					</div>
				</div>
			</div>

			<div
				class="border-base-300 bg-base-100 rounded-2xl border p-6 shadow-sm transition-shadow hover:shadow-md"
			>
				<div class="flex items-start gap-4">
					<div
						class="bg-primary/10 text-primary inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-xl"
					>
						<svg
							xmlns="http://www.w3.org/2000/svg"
							class="h-5 w-5"
							viewBox="0 0 20 20"
							fill="currentColor"
						>
							<path
								fill-rule="evenodd"
								d="M4 4a2 2 0 012-2h4.586A2 2 0 0112 2.586L15.414 6A2 2 0 0116 7.414V16a2 2 0 01-2 2H6a2 2 0 01-2-2V4zm2 6a1 1 0 011-1h6a1 1 0 110 2H7a1 1 0 01-1-1zm1 3a1 1 0 100 2h6a1 1 0 100-2H7z"
								clip-rule="evenodd"></path>
						</svg>
					</div>
					<div class="flex-1">
						<h2 class="font-display mb-1 text-lg font-bold">Printables</h2>
						<p class="text-base-content/70 mb-3 text-sm">
							Coloring pages, journal pages, and study guides. Free.
						</p>
						<span class="badge badge-warning badge-soft text-xs">Coming soon</span>
					</div>
				</div>
			</div>

			<div
				class="border-base-300 bg-base-100 rounded-2xl border p-6 shadow-sm transition-shadow hover:shadow-md"
			>
				<div class="flex items-start gap-4">
					<div
						class="bg-primary/10 text-primary inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-xl"
					>
						<svg
							xmlns="http://www.w3.org/2000/svg"
							class="h-5 w-5"
							viewBox="0 0 20 20"
							fill="currentColor"
						>
							<path
								d="M9 4.804A7.968 7.968 0 005.5 4c-1.255 0-2.443.29-3.5.804v10A7.969 7.969 0 015.5 14c1.669 0 3.218.51 4.5 1.385A7.962 7.962 0 0114.5 14c1.255 0 2.443.29 3.5.804v-10A7.968 7.968 0 0014.5 4c-1.255 0-2.443.29-3.5.804V12a1 1 0 11-2 0V4.804z"
							></path>
						</svg>
					</div>
					<div class="flex-1">
						<h2 class="font-display mb-1 text-lg font-bold">Darbees Bookshelf</h2>
						<p class="text-base-content/70 mb-3 text-sm">
							Family book reviews with Dad's take, Mom's take, and kids' take. Christian discernment
							for every age and format.
						</p>
						<a
							href="/bookshelf"
							class="text-primary inline-flex items-center gap-1 text-sm font-medium hover:underline"
						>
							<span>Browse the bookshelf</span>
							<svg
								xmlns="http://www.w3.org/2000/svg"
								class="h-4 w-4"
								viewBox="0 0 20 20"
								fill="currentColor"
							>
								<path
									fill-rule="evenodd"
									d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z"
									clip-rule="evenodd"></path>
							</svg>
						</a>
					</div>
				</div>
			</div>

			<div
				class="border-base-300 bg-base-100 rounded-2xl border p-6 shadow-sm transition-shadow hover:shadow-md"
			>
				<div class="flex items-start gap-4">
					<div
						class="bg-primary/10 text-primary inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-xl"
					>
						<svg
							xmlns="http://www.w3.org/2000/svg"
							class="h-5 w-5"
							viewBox="0 0 20 20"
							fill="currentColor"
						>
							<path
								fill-rule="evenodd"
								d="M8 4a4 4 0 100 8 4 4 0 000-8zM2 8a6 6 0 1110.89 3.476l4.817 4.817a1 1 0 01-1.414 1.414l-4.816-4.816A6 6 0 012 8z"
								clip-rule="evenodd"></path>
						</svg>
					</div>
					<div class="flex-1">
						<h2 class="font-display mb-1 text-lg font-bold">Field Notes Starter Pack</h2>
						<p class="text-base-content/70 mb-3 text-sm">
							Printable observation sheets, vocabulary cards, and a family field journal guide for
							nature and history outings.
						</p>
						<span class="badge badge-warning badge-soft text-xs">Coming soon</span>
					</div>
				</div>
			</div>

			<div
				class="border-base-300 bg-base-100 rounded-2xl border p-6 shadow-sm transition-shadow hover:shadow-md"
			>
				<div class="flex items-start gap-4">
					<div
						class="bg-primary/10 text-primary inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-xl"
					>
						<svg
							xmlns="http://www.w3.org/2000/svg"
							class="h-5 w-5"
							viewBox="0 0 20 20"
							fill="currentColor"
						>
							<path
								d="M8 16.5a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0zM15 16.5a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0z"
							></path>
							<path
								d="M3 4a1 1 0 00-1 1v10a1 1 0 001 1h1.05a2.5 2.5 0 014.9 0H10a1 1 0 001-1v-1h3.05a2.5 2.5 0 014.9 0H19a1 1 0 001-1v-2a4 4 0 00-4-4h-3V4a1 1 0 00-1-1H3z"
							></path>
						</svg>
					</div>
					<div class="flex-1">
						<h2 class="font-display mb-1 text-lg font-bold">RV Moving-Day Checklist</h2>
						<p class="text-base-content/70 mb-3 text-sm">
							Inside and outside walkthrough checklists for hitching up, breaking camp, and arriving
							without forgetting anything important.
						</p>
						<span class="badge badge-warning badge-soft text-xs">Coming soon</span>
					</div>
				</div>
			</div>
		</div>
	</article>
</BaseLayout>
