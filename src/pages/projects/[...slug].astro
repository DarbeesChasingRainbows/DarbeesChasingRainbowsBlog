---
import { type CollectionEntry, render } from 'astro:content';
import { getProjects } from '../../utils/getPosts';
import { readingTime } from '../../utils/readingTime';
import ProjectPostLayout from '../../layouts/ProjectPostLayout.astro';

export async function getStaticPaths() {
	const projects = await getProjects();
	return projects.map((post) => ({
		params: { slug: post.id },
		props: { post },
	}));
}

type Props = { post: CollectionEntry<'projects'> };

const { post } = Astro.props;
const { Content, headings } = await render(post);
const minutes = readingTime(post.body ?? '');
---

<ProjectPostLayout post={post} headings={headings} readingTime={minutes}>
	<Content />
</ProjectPostLayout>
