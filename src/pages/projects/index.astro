---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { getProjects, getCategories } from '../../utils/getPosts';

const projects = await getProjects();
const categories = getCategories(projects);
---

<BaseLayout
	title="Projects"
	description="DIY, RV automation, schematics, and useful builds we've shipped and documented."
>
	<section class="mx-auto max-w-7xl px-6 pt-10 pb-12 md:pt-14">
		<Breadcrumbs class="mb-6" items={[{ label: 'Home', href: '/' }, { label: 'Projects' }]} />
		<div class="grid items-end gap-8 lg:grid-cols-12">
			<div class="lg:col-span-8">
				<div class="mb-6 flex items-center gap-3">
					<span class="bg-primary inline-block h-px w-10"></span>
					<span class="eyebrow">The Workshop</span>
				</div>
				<h1 class="font-editorial text-[clamp(3rem,8vw,7rem)]">
					Things we <span class="text-accent italic">built</span>.
				</h1>
				<p class="text-base-content/70 mt-6 max-w-xl text-lg leading-relaxed">
					DIY, RV automation, schematics, and useful builds we've shipped and documented. Parts
					lists and code included where it helps.
				</p>
			</div>
			{
				categories.length > 0 && (
					<div class="lg:border-primary/15 lg:col-span-4 lg:border-l lg:pl-8">
						<div class="eyebrow mb-3">Kinds of builds</div>
						<div class="font-display text-base-content/75 flex flex-wrap gap-x-4 gap-y-1 font-bold">
							{categories.map((c, i) => (
								<>
									{i > 0 && <span class="text-base-content/30">·</span>}
									<span>{c}</span>
								</>
							))}
						</div>
						<p class="text-base-content/55 mt-4 text-sm">
							{projects.length} {projects.length === 1 ? 'project' : 'projects'} documented.
						</p>
					</div>
				)
			}
		</div>
	</section>

	{
		projects.length === 0 ? (
			<section class="mx-auto max-w-3xl px-6 py-24 text-center">
				<p class="font-editorial text-base-content/40 text-3xl">
					No projects published yet. We're building.
				</p>
			</section>
		) : (
			<section class="mx-auto max-w-7xl px-6 pb-16">
				<div class="mb-10 flex items-baseline gap-4">
					<span class="eyebrow">All builds</span>
					<span class="border-base-content/15 flex-1 border-t" />
					<span class="font-display text-base-content/50 text-xs font-bold tracking-[0.2em] uppercase tabular-nums">
						{projects.length} projects
					</span>
				</div>
				<div class="grid gap-x-8 gap-y-12 sm:grid-cols-2 lg:grid-cols-3">
					{projects.map((project) => (
						<PostCard kind="project" entry={project} />
					))}
				</div>
			</section>
		)
	}
</BaseLayout>
