---
import BaseLayout from '../layouts/BaseLayout.astro';
import NewsletterSignup from '../components/NewsletterSignup.astro';

const pillars = [
	{
		title: 'RV Life',
		href: '/rv-life',
		description:
			"The honest road between the house that wasn't forever and the roots we're working toward. What it gives. What it costs. What we'd tell you before you do it.",
		tag: '01',
	},
	{
		title: 'Homeschool',
		href: '/homeschool',
		description:
			'A rich, rigorous education in a small space. Classical influences, living books, read-alouds, field learning, and a Christ-centered foundation.',
		tag: '02',
	},
	{
		title: 'Field Notes',
		href: '/field-notes',
		description:
			'Hikes, historic sites, nature identification, and location-based learning. What we noticed, wondered, and learned on the trail.',
		tag: '03',
	},
	{
		title: 'Projects & Builds',
		href: '/projects',
		description:
			'Practical DIY and RV automation — sensor systems, schematics, code, and useful builds documented honestly. Future farm systems too.',
		tag: '04',
	},
	{
		title: 'Kingdom Farm',
		href: '/kingdom-farm',
		description:
			"The long-term mission: a regenerative business-ministry built on clean food, hospitality, and stewardship. We don't have land yet. We're counting the cost.",
		tag: '05',
	},
	{
		title: 'Darbees Bookshelf',
		href: '/bookshelf',
		description:
			"Family book reviews with a Dad's take, Mom's take, and kids' take. Christian discernment for kids, tweens, teens, and family read-alouds.",
		tag: '06',
	},
	{
		title: 'Faith & Reflections',
		href: '/category/Faith%20%26%20Reflections/',
		description:
			'Honest essays on faith, family, suffering, hope, and what it looks like to follow the Lord through uncertainty.',
		tag: '07',
	},
];

const nextSteps = [
	{ label: 'Our Story', href: '/about', desc: 'The rainbow origin. The house. The faith.' },
	{ label: 'RV Life', href: '/rv-life', desc: 'Honest notes from the road.' },
	{ label: 'Homeschool', href: '/homeschool', desc: 'How we educate four kids on the move.' },
	{ label: 'Kingdom Farm', href: '/kingdom-farm', desc: 'The long-term mission.' },
	{
		label: 'Darbees Bookshelf',
		href: '/bookshelf',
		desc: "Books we've read and reviewed as a family.",
	},
	{ label: 'Resources', href: '/resources', desc: 'Free templates, field notes, and tools.' },
];
---

<BaseLayout
	title="Start Here"
	description="New to Darbees Chasing Rainbows? This is the best place to begin — who we are, what this site is about, and where to go next."
>
	<article class="mx-auto max-w-4xl px-4 py-16 md:py-24">
		<!-- Hero -->
		<div class="mb-16 text-center md:mb-20">
			<div class="eyebrow mb-4">Welcome</div>
			<h1 class="font-editorial text-base-content mb-6 text-5xl md:text-7xl">Start Here</h1>
			<p class="text-base-content/70 mx-auto max-w-2xl text-xl leading-relaxed md:text-2xl">
				If you're new to Darbees Chasing Rainbows, this is the best place to begin.
			</p>
		</div>

		<!-- Who we are -->
		<div class="prose prose-lg mb-16 max-w-none">
			<h2>Who we are</h2>
			<p>
				We are the Darbee family — a Christian family of six living and homeschooling full-time in
				our RV. We have four kids. We're learning in public. We work a real job, do real schooling,
				fix real things when they break, and work toward a vision called Kingdom Farm.
			</p>
			<p>
				We are not here to make this look easy or glamorous. We're here to document the real work of
				building a faithful, capable, honest family life — and to share what we learn along the way.
			</p>
		</div>

		<!-- Short rainbow origin -->
		<div class="border-primary/20 bg-primary/5 mb-16 rounded-3xl border p-8 md:p-10">
			<h2 class="font-display mb-4 text-2xl font-bold">Why "Darbees Chasing Rainbows"</h2>
			<p class="text-base-content/80 mb-4">
				Darbee is our last name. The "chasing rainbows" part came from one of the hardest seasons
				we've walked through.
			</p>
			<p class="text-base-content/80 mb-4">
				In 2023, we were trying to sell the house we thought would be our forever home while living
				in a tiny RV on the property. We kept asking the Lord what He was doing. We didn't know. And
				again and again, in moments of discouragement, we would see a rainbow.
			</p>
			<p class="text-base-content mb-4 font-medium">
				Those rainbows became reminders that God hadn't forgotten us. That's where this name came
				from.
			</p>
			<a
				href="/about"
				class="font-display text-primary inline-flex items-center gap-2 text-sm font-bold tracking-wide transition-all hover:gap-3"
			>
				Read the full story →
			</a>
		</div>

		<!-- What this site is about -->
		<div class="mb-16">
			<div class="mb-10">
				<span class="eyebrow">What you'll find here</span>
				<h2 class="font-editorial mt-3 text-4xl md:text-5xl">The seven departments.</h2>
			</div>
			<div class="grid gap-x-8 gap-y-2 sm:grid-cols-2">
				{
					pillars.map((p) => (
						<a
							href={p.href}
							class="group border-base-content/15 hover:border-primary flex items-start gap-5 border-t py-6 transition-colors"
						>
							<span class="font-display text-primary/40 group-hover:text-primary pt-1 text-3xl font-black tracking-tight tabular-nums transition-colors">
								{p.tag}
							</span>
							<div class="flex-1">
								<h3 class="font-display group-hover:text-primary mb-1 text-lg font-bold transition-colors">
									{p.title}
								</h3>
								<p class="text-base-content/65 text-sm leading-relaxed">{p.description}</p>
							</div>
						</a>
					))
				}
			</div>
		</div>

		<!-- Kingdom Farm -->
		<div class="bg-base-200 mb-16 rounded-3xl p-8 md:p-10">
			<h2 class="font-display mb-4 text-2xl font-bold">What is Kingdom Farm?</h2>
			<p class="text-base-content/80 mb-4">
				Kingdom Farm is the long-term mission underlying everything on this site. It is our vision
				for a regenerative business-ministry — a farm that grows excellent food, serves families
				across income levels, builds local food independence, and runs on faithful stewardship.
			</p>
			<p class="text-base-content/80 mb-4">
				We don't have land yet. We're scouting north Georgia, studying regenerative farming,
				counting the cost, and building toward it honestly. Kingdom Farm is the major earthly
				destination — but not the final one. The deeper goal is to become the kind of family that
				can build, steward, serve, and endure faithfully wherever the Lord leads.
			</p>
			<a
				href="/kingdom-farm"
				class="font-display text-primary inline-flex items-center gap-2 text-sm font-bold tracking-wide transition-all hover:gap-3"
			>
				Follow the Kingdom Farm journey →
			</a>
		</div>

		<!-- How we share -->
		<div class="mb-16">
			<h2 class="font-display mb-6 text-2xl font-bold">How we share</h2>
			<div class="grid gap-4 sm:grid-cols-2">
				<div class="border-base-300 rounded-2xl border p-5">
					<div class="mb-1 font-semibold">No children's faces</div>
					<p class="text-base-content/70 text-sm">
						We share family life, but we do not make our children the product. You'll see their
						projects, hikes, and notebooks — not their faces or private moments.
					</p>
				</div>
				<div class="border-base-300 rounded-2xl border p-5">
					<div class="mb-1 font-semibold">Tell the truth, not everything</div>
					<p class="text-base-content/70 text-sm">
						We're honest about costs, failures, and hard things. We also protect what needs to be
						protected.
					</p>
				</div>
				<div class="border-base-300 rounded-2xl border p-5">
					<div class="mb-1 font-semibold">No display ads</div>
					<p class="text-base-content/70 text-sm">
						We keep the site clean. Affiliate links are disclosed and limited to things we actually
						use. No clutter.
					</p>
				</div>
				<div class="border-base-300 rounded-2xl border p-5">
					<div class="mb-1 font-semibold">Transparent monetization</div>
					<p class="text-base-content/70 text-sm">
						We try to monetize the resources, not the relationship. <a
							href="/support"
							class="text-primary hover:underline">How this site is supported →</a
						>
					</p>
				</div>
			</div>
		</div>

		<!-- Where to go next -->
		<div class="mb-16">
			<span class="eyebrow mb-4 block">Where to go next</span>
			<div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
				{
					nextSteps.map((step) => (
						<a
							href={step.href}
							class="group border-base-300 hover:border-primary hover:bg-primary/5 rounded-2xl border p-6 transition-all"
						>
							<div class="font-display text-base-content group-hover:text-primary mb-1 font-bold transition-colors">
								{step.label}
							</div>
							<div class="text-base-content/65 text-sm">{step.desc}</div>
						</a>
					))
				}
			</div>
		</div>

		<!-- Newsletter -->
		<div class="border-base-300 border-t pt-12">
			<div class="mb-8 text-center">
				<h2 class="font-display mb-2 text-2xl font-bold">The Darbees Dispatch</h2>
				<p class="text-base-content/70 mx-auto max-w-md">
					Monthly updates from the road — what we're learning, what we're reading, what broke, field
					notes, and Kingdom Farm progress.
				</p>
			</div>
			<NewsletterSignup />
		</div>
	</article>
</BaseLayout>
