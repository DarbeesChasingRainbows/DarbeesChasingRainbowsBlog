---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { getFieldNotes } from '../../utils/getPosts';

const notes = await getFieldNotes();
const regions = Array.from(new Set(notes.map((n) => n.data.region).filter(Boolean))) as string[];
---

<BaseLayout
	title="Field Notes"
	description="Hikes, historic sites, nature studies, and homeschool field trips. Real places, real questions, written down."
>
	<section class="mx-auto max-w-7xl px-6 pt-10 pb-12 md:pt-14">
		<Breadcrumbs class="mb-6" items={[{ label: 'Home', href: '/' }, { label: 'Field Notes' }]} />
		<div class="grid items-end gap-8 lg:grid-cols-12">
			<div class="lg:col-span-8">
				<div class="mb-6 flex items-center gap-3">
					<span class="bg-primary inline-block h-px w-10"></span>
					<span class="eyebrow">The Trail Log</span>
				</div>
				<h1 class="font-editorial text-[clamp(3rem,8vw,7rem)]">
					Real places, <span class="text-accent italic">written down</span>.
				</h1>
				<p class="text-base-content/70 mt-6 max-w-xl text-lg leading-relaxed">
					Hikes, historic sites, nature studies, and homeschool field trips — short dispatches from
					the road.
				</p>
			</div>
			{
				regions.length > 0 && (
					<div class="lg:border-primary/15 lg:col-span-4 lg:border-l lg:pl-8">
						<div class="eyebrow mb-3">Regions visited</div>
						<div class="font-display text-base-content/75 flex flex-wrap gap-x-4 gap-y-1 font-bold">
							{regions.map((r, i) => (
								<>
									{i > 0 && <span class="text-base-content/30">·</span>}
									<span class="text-base-content/80">{r}</span>
								</>
							))}
						</div>
						<p class="text-base-content/55 mt-4 text-sm">
							{notes.length} {notes.length === 1 ? 'note' : 'notes'} filed so far.
						</p>
					</div>
				)
			}
		</div>
	</section>

	{
		notes.length === 0 ? (
			<section class="mx-auto max-w-3xl px-6 py-24 text-center">
				<p class="font-editorial text-base-content/40 text-3xl">
					No field notes yet. We're out walking.
				</p>
			</section>
		) : (
			<section class="mx-auto max-w-7xl px-6 pb-16">
				<div class="mb-10 flex items-baseline gap-4">
					<span class="eyebrow">All entries</span>
					<span class="border-base-content/15 flex-1 border-t" />
					<span class="font-display text-base-content/50 text-xs font-bold tracking-[0.2em] uppercase tabular-nums">
						{notes.length} entries
					</span>
				</div>
				<div class="grid gap-x-8 gap-y-12 sm:grid-cols-2 lg:grid-cols-3">
					{notes.map((note) => (
						<PostCard kind="field-note" entry={note} />
					))}
				</div>
			</section>
		)
	}
</BaseLayout>
