---
// Thin wrapper around PostLayout for field notes. The two collection-specific
// pieces are: the location/region/weather metadata grid (slot="meta") and the
// homeschool badge (slot="header-extras").

import type { CollectionEntry } from 'astro:content';
import type { MarkdownHeading } from 'astro';
import PostLayout from './PostLayout.astro';
import PostMeta from '../components/PostMeta.astro';
import FieldNotesBlock from '../components/FieldNotesBlock.astro';
import { getFieldNotes, getAdjacentPosts, getRelatedPostsCrossCollection } from '../utils/getPosts';

const allNotes = await getFieldNotes();

interface Props {
	post: CollectionEntry<'field-notes'>;
	headings?: MarkdownHeading[];
	// readingTime accepted for parity with the other post layouts; field notes
	// don't display it because the metadata grid above already shows date/place.
	readingTime?: number;
}

const { post, headings = [], readingTime } = Astro.props;
const { data } = post;
const hero = data.featuredImage ?? data.heroImage;
const heroImage = hero && typeof hero === 'object' && 'src' in hero ? hero : undefined;

const { prev, next } = getAdjacentPosts(allNotes, post.id);
const related = await getRelatedPostsCrossCollection(post, 3);

// Format date for the block
const displayDate = data.pubDate.toLocaleDateString('en-US', {
	year: 'numeric',
	month: 'long',
	day: 'numeric',
});

// Check if we have any observations to show
const hasObservations = data.saw?.length || data.heard || data.wondered || data.learned;
---

<PostLayout
	title={data.title}
	description={data.description}
	hero={heroImage}
	imageAlt={data.imageAlt}
	imageAttribution={data.imageAttribution}
	publishDate={data.pubDate}
	category={data.category}
	tags={data.tags}
	headings={headings}
	keyTakeaways={data.keyTakeaways}
	faq={data.faq}
	sources={data.sources}
	aiSummary={data.aiSummary}
	draft={data.draft}
	collection="field-notes"
	collectionLabel="Field Notes"
	collectionHref="/field-notes"
	backLabel="all field notes"
	prev={prev}
	next={next}
	related={related}
>
	<Fragment slot="meta">
		<PostMeta
			pubDate={data.pubDate}
			category={data.category}
			categoryHref={`/category/${encodeURIComponent(data.category)}/`}
			readingTime={readingTime}
			class="mb-6"
		/>
		<dl
			class="border-base-300 bg-base-200/40 grid grid-cols-2 gap-3 rounded-xl border p-4 text-sm sm:grid-cols-3"
		>
			<div>
				<dt class="text-base-content/60 text-xs tracking-wide uppercase">Location</dt>
				<dd class="mt-1 font-medium">{data.location}</dd>
			</div>
			{
				data.region && (
					<div>
						<dt class="text-base-content/60 text-xs tracking-wide uppercase">Region</dt>
						<dd class="mt-1 font-medium">{data.region}</dd>
					</div>
				)
			}
			{
				data.weather && (
					<div>
						<dt class="text-base-content/60 text-xs tracking-wide uppercase">Weather</dt>
						<dd class="mt-1 font-medium">{data.weather}</dd>
					</div>
				)
			}
		</dl>
	</Fragment>

	{
		data.includesHomeschool && (
			<p slot="header-extras" class="mt-3">
				<span class="badge badge-secondary badge-soft">🎒 Includes homeschool material</span>
			</p>
		)
	}

	{
		hasObservations && (
			<FieldNotesBlock
				location={data.location}
				date={displayDate}
				weather={data.weather}
				saw={data.saw}
				heard={data.heard}
				wondered={data.wondered}
				learned={data.learned}
			/>
		)
	}

	<slot />
</PostLayout>
