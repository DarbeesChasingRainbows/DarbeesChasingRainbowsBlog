---
// Thin wrapper around PostLayout for projects. The collection-specific pieces:
//   - meta slot: a 4-cell <dl> for difficulty / cost / time / github
//   - before-content slot: ProjectPartsList rendered from data.partsList
//   - extraJsonLd: a HowTo node when partsList is present

import type { CollectionEntry } from 'astro:content';
import type { MarkdownHeading } from 'astro';
import PostLayout from './PostLayout.astro';
import PostMeta from '../components/PostMeta.astro';
import ProjectPartsList from '../components/ProjectPartsList.astro';
import { getProjects, getAdjacentPosts, getRelatedPostsCrossCollection } from '../utils/getPosts';
import { DIFFICULTY_COLORS } from '../consts';
import { buildHowToJsonLd } from '../utils/seo';

const allProjects = await getProjects();

interface Props {
	post: CollectionEntry<'projects'>;
	headings?: MarkdownHeading[];
	readingTime?: number;
}

const { post, headings = [], readingTime } = Astro.props;
const { data } = post;
const hero = data.featuredImage ?? data.heroImage;
const heroImage = hero && typeof hero === 'object' && 'src' in hero ? hero : undefined;

const { prev, next } = getAdjacentPosts(allProjects, post.id);
const related = await getRelatedPostsCrossCollection(post, 3);

const heroUrl = heroImage ? new URL(heroImage.src, Astro.site).toString() : undefined;

// Projects get an extra HowTo JSON-LD node when they declare a parts list.
// Built here (not inside PostLayout) so PostLayout stays collection-agnostic.
const extraJsonLd = data.partsList?.length
	? [
			buildHowToJsonLd({
				name: data.title,
				description: data.description,
				image: heroUrl,
				estimatedCost: data.estimatedCost,
				totalTime: data.estimatedTime,
				supplies: data.partsList.map((p) => ({ name: p.name, quantity: p.quantity })),
			}),
		]
	: [];
---

<PostLayout
	title={data.title}
	description={data.description}
	hero={heroImage}
	imageAlt={data.imageAlt}
	imageAttribution={data.imageAttribution}
	publishDate={data.pubDate}
	updatedDate={data.updatedDate}
	category={data.category}
	tags={data.tags}
	headings={headings}
	keyTakeaways={data.keyTakeaways}
	faq={data.faq}
	sources={data.sources}
	aiSummary={data.aiSummary}
	draft={data.draft}
	collection="projects"
	collectionLabel="Projects"
	collectionHref="/projects"
	backLabel="all projects"
	prev={prev}
	next={next}
	related={related}
	extraJsonLd={extraJsonLd}
>
	<Fragment slot="meta">
		<PostMeta
			pubDate={data.pubDate}
			updatedDate={data.updatedDate}
			category={data.category}
			categoryHref={`/category/${encodeURIComponent(data.category)}/`}
			readingTime={readingTime}
		/>
		<dl class="mt-6 grid grid-cols-2 gap-3 text-sm sm:grid-cols-4">
			{
				data.difficulty && (
					<div class="bg-base-200 rounded-xl p-3">
						<dt class="text-base-content/60 text-xs tracking-wide uppercase">Difficulty</dt>
						<dd class="mt-1">
							<span class={`badge ${DIFFICULTY_COLORS[data.difficulty]} badge-soft capitalize`}>
								{data.difficulty}
							</span>
						</dd>
					</div>
				)
			}
			{
				data.estimatedCost && (
					<div class="bg-base-200 rounded-xl p-3">
						<dt class="text-base-content/60 text-xs tracking-wide uppercase">Cost</dt>
						<dd class="mt-1 font-medium">{data.estimatedCost}</dd>
					</div>
				)
			}
			{
				data.estimatedTime && (
					<div class="bg-base-200 rounded-xl p-3">
						<dt class="text-base-content/60 text-xs tracking-wide uppercase">Time</dt>
						<dd class="mt-1 font-medium">{data.estimatedTime}</dd>
					</div>
				)
			}
			{
				data.githubUrl && (
					<div class="bg-base-200 rounded-xl p-3">
						<dt class="text-base-content/60 text-xs tracking-wide uppercase">Code</dt>
						<dd class="mt-1">
							<a
								href={data.githubUrl}
								target="_blank"
								rel="noopener"
								class="link link-primary text-sm"
							>
								GitHub →
							</a>
						</dd>
					</div>
				)
			}
		</dl>
	</Fragment>

	{
		data.partsList && data.partsList.length > 0 && (
			<ProjectPartsList slot="before-content" items={data.partsList} />
		)
	}

	<slot />
</PostLayout>
