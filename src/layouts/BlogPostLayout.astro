---
// Thin wrapper around PostLayout — handles the blog-specific data fetching
// (adjacent posts, related posts) and forwards everything to PostLayout.
//
// Compared to before: this file is ~30 lines instead of ~150 because the
// shared structure now lives in PostLayout.

import type { CollectionEntry } from 'astro:content';
import type { MarkdownHeading } from 'astro';
import PostLayout from './PostLayout.astro';
import PostMeta from '../components/PostMeta.astro';
import { getBlogPosts, getAdjacentPosts, getRelatedPostsCrossCollection } from '../utils/getPosts';

const allBlog = await getBlogPosts();

interface Props {
	post: CollectionEntry<'blog'>;
	headings?: MarkdownHeading[];
	readingTime?: number;
}

const { post, headings = [], readingTime } = Astro.props;
const { data } = post;
const hero = data.featuredImage ?? data.heroImage;
const heroImage = hero && typeof hero === 'object' && 'src' in hero ? hero : undefined;

const { prev, next } = getAdjacentPosts(allBlog, post.id);
const related = await getRelatedPostsCrossCollection(post, 3);

---

<PostLayout
	title={data.title}
	description={data.description}
	hero={heroImage}
	imageAlt={data.imageAlt}
	imageAttribution={data.imageAttribution}
	publishDate={data.pubDate}
	updatedDate={data.updatedDate}
	author={data.author}
	category={data.category}
	tags={data.tags}
	headings={headings}
	keyTakeaways={data.keyTakeaways}
	faq={data.faq}
	sources={data.sources}
	aiSummary={data.aiSummary}
	draft={data.draft}
	collection="blog"
	collectionLabel="Blog"
	collectionHref="/blog"
	backLabel="all posts"
	prev={prev}
	next={next}
	related={related}
>
	<PostMeta
		slot="meta"
		pubDate={data.pubDate}
		updatedDate={data.updatedDate}
		author={data.author}
		category={data.category}
		categoryHref={`/category/${encodeURIComponent(data.category)}/`}
		readingTime={readingTime}
	/>

	<slot />
</PostLayout>
